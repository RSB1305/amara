---
interface CtaLink {
  href: string;
  label: string;
}

interface Props {
  kicker?: string;
  detail?: string;
  title?: string;
  titleHtml?: string;
  subtitle?: string;
  lead: string;
  support?: string;
  supportText?: string;
  primaryCta?: CtaLink;
  secondaryCta?: CtaLink;
  ctaLinks?: CtaLink[];
  dataLang?: string;
}

const {
  kicker,
  detail,
  title,
  titleHtml,
  subtitle,
  lead,
  support,
  supportText,
  primaryCta,
  secondaryCta,
  ctaLinks = [],
  dataLang
} = Astro.props;

const heroMeta = subtitle ?? [kicker, detail].filter(Boolean).join(' · ');
const heroSupport = supportText ?? support;
const heroTitle = titleHtml ?? title ?? '';
const links =
  ctaLinks.length > 0
    ? ctaLinks
    : [primaryCta, secondaryCta].filter((link): link is CtaLink => Boolean(link));
---

<header class="am-exp-hero" data-lang={dataLang}>
  {heroMeta && (
    <div class="am-exp-hero__meta">
      <span class="am-kicker am-gold">{heroMeta}</span>
    </div>
  )}
  <h1 class="am-exp-hero__title" set:html={heroTitle} />
  <p class="am-exp-hero__lead">{lead}</p>
  {heroSupport && <p class="am-hero-support">{heroSupport}</p>}
  {links.length > 0 && (
    <div class="am-cta-group am-cta-group--left mt-8">
      {links.map((link, index) => (
        <>
          {index > 0 && <span class="am-exp-cta__dot">&middot;</span>}
          <a href={link.href} class="am-cta-link">
            {link.label}
          </a>
        </>
      ))}
    </div>
  )}
</header>

<style>
  .am-exp-hero {
    padding: clamp(2rem, 4vw, 2.5rem) 0 clamp(4rem, 8vw, 8rem);
  }

  .am-exp-hero__meta {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 3rem;
    opacity: 0.6;
  }

  .am-exp-hero__title {
    font-family: "Newsreader", serif;
    font-size: clamp(3.5rem, 7vw, 6rem);
    line-height: 1.05;
    font-weight: 300;
    letter-spacing: -0.02em;
    color: #111;
    max-width: 12ch;
    margin: 0 0 2.5rem 0;
  }

  @media (min-width: 1024px) {
    .am-exp-hero__title {
      max-width: 18ch;
    }
  }

  .am-exp-hero__lead {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    line-height: 1.6;
    color: #444;
    max-width: 35ch;
  }

  .am-hero-support {
    margin-top: 1.5rem;
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 0.95rem;
    line-height: 1.6;
    color: #666;
    font-style: italic;
  }
</style>
