---
/**
 * Home: single editorial “featured stay” band — image + calm copy, not a promo tile.
 */
interface Props {
  eyebrow: string;
  propertyName: string;
  locationTag: string;
  body: string;
  ctaLabel: string;
  ctaHref: string;
}

const { eyebrow, propertyName, locationTag, body, ctaLabel, ctaHref } = Astro.props;
---

<section class="am-home-featured border-t border-outline-variant/10 py-16 md:py-24" aria-labelledby="home-featured-heading">
  <p class="am-home-featured__eyebrow am-text-caption text-on-surface-variant">{eyebrow}</p>
  <div class="am-home-featured__grid">
    <div class="am-home-featured__media">
      <div class="am-home-featured__placeholder" aria-hidden="true" />
    </div>
    <div class="am-home-featured__copy">
      <h2 id="home-featured-heading" class="am-home-featured__title">
        {propertyName}
      </h2>
      <p class="am-home-featured__tag">{locationTag}</p>
      <p class="am-home-featured__body">{body}</p>
      <div class="am-home-featured__cta">
        <a href={ctaHref} class="am-btn am-btn--ghost">
          {ctaLabel}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  @reference "../../styles/global.css";

  .am-home-featured__eyebrow {
    letter-spacing: 0.22em;
    margin: 0 0 2rem 0;
  }

  .am-home-featured__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .am-home-featured__grid {
      grid-template-columns: 3fr 2fr;
      gap: clamp(2rem, 4vw, 3.5rem);
    }
  }

  .am-home-featured__media {
    width: 100%;
    max-width: 56rem;
  }

  .am-home-featured__placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: var(--color-surface-container-high);
    border-radius: 0.125rem;
  }

  .am-home-featured__title {
    margin: 0 0 0.75rem 0;
  }

  .am-home-featured__tag {
    letter-spacing: 0.06em;
    margin: 0 0 1.5rem 0;
  }

  .am-home-featured__body {
    line-height: 1.7;
    margin: 0 0 2rem 0;
    max-width: 38ch;
  }

  .am-home-featured__cta {
    margin-top: 0.25rem;
  }
</style>
