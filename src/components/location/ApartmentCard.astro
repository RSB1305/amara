---
/**
 * Property listing card: image, meta, title, description, CTA.
 * Styling uses design tokens only (no raw hex).
 */
interface Props {
  href: string;
  imageSrc: string;
  imageAlt: string;
  meta: string;
  title: string;
  description: string;
  ctaLabel: string;
}

const { href, imageSrc, imageAlt, meta, title, description, ctaLabel } = Astro.props;
---

<div class="am-apartment-card am-apartment-card--hover">
  <figure class="am-apartment-card__figure">
    <a href={href} aria-label={`View ${title}`} class="am-apartment-card__image-link">
      <img
        src={imageSrc}
        alt={imageAlt}
        class="am-apartment-card__image"
        loading="lazy"
        width="800"
        height="600"
      />
    </a>
  </figure>
  <div class="am-apartment-card__body">
    <small class="am-apartment-card__meta">{meta}</small>
    <h3 class="am-apartment-card__title">{title}</h3>
    <p class="am-apartment-card__description">{description}</p>
    <div class="am-apartment-card__cta-wrap">
      <a class="am-apartment-card__cta" href={href}>{ctaLabel}</a>
    </div>
  </div>
</div>

<style>
  @reference "../../styles/global.css";

  .am-apartment-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .am-apartment-card__figure {
    margin: 0;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background-color: var(--color-surface-container-low);
  }

  .am-apartment-card__image-link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .am-apartment-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 700ms ease;
  }

  .am-apartment-card--hover:hover .am-apartment-card__image {
    transform: scale(1.05);
  }

  .am-apartment-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .am-apartment-card__meta {
    font-family: var(--font-label);
    font-size: 0.875rem;
    line-height: 1.5;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-on-surface-variant);
  }

  .am-apartment-card__title {
    font-family: var(--font-headline);
    font-size: 1.5rem;
    line-height: 1.25;
    font-weight: 300;
    color: var(--color-on-surface);
    margin: 0;
  }

  .am-apartment-card__description {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.625;
    color: var(--color-on-surface-variant);
    margin: 0;
  }

  .am-apartment-card__cta-wrap {
    margin-top: 0.75rem;
  }

  .am-apartment-card__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.25;
    border-radius: 9999px;
    border: 1px solid var(--color-outline);
    color: var(--color-on-surface);
    text-decoration: none;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  .am-apartment-card__cta:hover {
    border-color: var(--color-border-hover);
    background-color: var(--color-surface-container-low);
  }
</style>
