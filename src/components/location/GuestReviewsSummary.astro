---
/**
 * Trust band: guest rating headline, supporting copy, feature chips, reviews CTA.
 */
interface Feature {
  label: string;
  note?: string;
}

interface Props {
  eyebrow: string;
  headline: string;
  body: string;
  reviewsHref: string;
  reviewsCtaLabel: string;
  features: Feature[];
}

const { eyebrow, headline, body, reviewsHref, reviewsCtaLabel, features } = Astro.props;
---

<section id="am-trust-badge" class="am-guest-reviews-summary" aria-label="Guest reviews summary">
  <div class="am-guest-reviews-summary__inner">
    <div class="am-guest-reviews-summary__copy">
      <p class="am-guest-reviews-summary__eyebrow am-text-caption text-on-surface-variant">{eyebrow}</p>
      <h2 class="am-guest-reviews-summary__headline am-text-title text-on-surface">
        <span class="am-guest-reviews-summary__star am-gold" aria-hidden="true">★</span>
        {headline}
      </h2>
      <p class="am-guest-reviews-summary__body am-text-body text-on-surface-variant">{body}</p>
      <div class="am-guest-reviews-summary__cta-wrap">
        <a class="am-guest-reviews-summary__cta am-text-body font-medium" href={reviewsHref}>{reviewsCtaLabel}</a>
      </div>
    </div>

    <div class="am-guest-reviews-summary__chips" aria-label="Highlighted guest features">
      {
        features.map((feature) => (
          <span class="am-guest-reviews-summary__chip am-text-body">
            {feature.label}
            {feature.note && <span class="am-guest-reviews-summary__chip-note am-text-caption text-muted">{feature.note}</span>}
          </span>
        ))
      }
    </div>
  </div>
</section>

<style>
  @reference "../../styles/global.css";

  .am-guest-reviews-summary {
    position: relative;
    z-index: 10;
    max-width: 96rem;
    margin-left: auto;
    margin-right: auto;
    padding: 6rem 1.5rem;
    border-top: 1px solid var(--color-border-subtle);
  }

  @media (min-width: 768px) {
    .am-guest-reviews-summary {
      padding-left: 3rem;
      padding-right: 3rem;
    }
  }

  .am-guest-reviews-summary__inner {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    align-items: flex-start;
  }

  @media (min-width: 1024px) {
    .am-guest-reviews-summary__inner {
      flex-direction: row;
      gap: 4rem;
    }
  }

  .am-guest-reviews-summary__copy {
    flex: 1 1 0%;
    max-width: 42rem;
  }

  .am-guest-reviews-summary__eyebrow {
    letter-spacing: 0.05em;
    margin: 0 0 1.5rem 0;
  }

  .am-guest-reviews-summary__headline {
    margin: 0 0 1.5rem 0;
  }

  .am-guest-reviews-summary__star {
    margin-right: 0.75rem;
  }

  .am-guest-reviews-summary__body {
    line-height: 1.625;
    margin: 0 0 0.5rem 0;
  }

  .am-guest-reviews-summary__cta-wrap {
    margin-top: 0.5rem;
  }

  .am-guest-reviews-summary__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    line-height: 1.25;
    border-radius: 9999px;
    border: 1px solid var(--color-outline);
    color: var(--color-on-surface);
    text-decoration: none;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  .am-guest-reviews-summary__cta:hover {
    border-color: var(--color-border-hover);
    background-color: var(--color-surface-container-low);
  }

  .am-guest-reviews-summary__chips {
    flex: 1 1 0%;
    width: 100%;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding-top: 0;
  }

  @media (min-width: 1024px) {
    .am-guest-reviews-summary__chips {
      padding-top: 3rem;
    }
  }

  .am-guest-reviews-summary__chip {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.625rem 1.25rem;
    border: 1px solid var(--color-outline-variant);
    border-radius: 9999px;
    line-height: 1.4;
    color: var(--color-on-surface-variant);
    background-color: var(--color-surface-container-lowest);
  }

  .am-guest-reviews-summary__chip-note {
    margin-left: 0.25rem;
  }
</style>
