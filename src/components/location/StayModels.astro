---
/**
 * StayModels
 *
 * 1:1 extract from AI Studio FrigilianaParking.astro — stay model comparison.
 * Icons: Mountain, Home, Car (lucide-react). Middle column = dark “Balance” card.
 */
import { Mountain, Home, Car } from 'lucide-react';

export interface StayModelsColumn {
  title: string;
  description: string;
  frictionValue: string;
  carAccessValue: string;
}

export interface Props {
  title: string;
  intro: string;
  /** Shared row labels (e.g. “Friction”, “Car Access”) for all three cards */
  frictionLabel: string;
  carAccessLabel: string;
  left: StayModelsColumn;
  /** Middle card: dark theme + balance badge */
  center: StayModelsColumn & { balanceBadge: string };
  right: StayModelsColumn;
}

const { title, intro, frictionLabel, carAccessLabel, left, center, right } = Astro.props;
---

<section class="py-16 px-6 md:px-12 lg:px-24 max-w-[1600px] mx-auto">
  <div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
    <div>
      <h2 class="am-text-title mb-4">{title}</h2>
      <p class="am-text-body text-on-surface-variant font-light max-w-xl">
        {intro}
      </p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="border border-surface-container-high bg-surface-white p-8 flex flex-col h-full">
      <div class="mb-8">
        <Mountain className="w-6 h-6 text-on-surface mb-4" strokeWidth={1.5} />
        <h3 class="am-text-subtitle mb-2">{left.title}</h3>
        <p class="am-text-body text-on-surface-variant font-light">{left.description}</p>
      </div>
      <div class="mt-auto space-y-4">
        <div class="flex justify-between items-center border-t border-surface-container-high pt-4">
          <span class="am-text-caption uppercase tracking-wider text-muted">{frictionLabel}</span>
          <span class="am-text-body font-medium">{left.frictionValue}</span>
        </div>
        <div class="flex justify-between items-center border-t border-surface-container-high pt-4">
          <span class="am-text-caption uppercase tracking-wider text-muted">{carAccessLabel}</span>
          <span class="am-text-body font-medium">{left.carAccessValue}</span>
        </div>
      </div>
    </div>

    <div class="border border-on-surface bg-on-surface text-surface-white p-8 flex flex-col h-full relative overflow-hidden">
      <div class="absolute top-0 right-0 bg-surface-white text-on-surface am-text-caption uppercase tracking-widest px-3 py-1 m-4">
        {center.balanceBadge}
      </div>
      <div class="mb-8">
        <Home className="w-6 h-6 text-surface-white mb-4" strokeWidth={1.5} />
        <h3 class="am-text-subtitle mb-2">{center.title}</h3>
        <p class="am-text-body text-faint font-light">{center.description}</p>
      </div>
      <div class="mt-auto space-y-4">
        <div class="flex justify-between items-center border-t border-surface-white/20 pt-4">
          <span class="am-text-caption uppercase tracking-wider text-faint">{frictionLabel}</span>
          <span class="am-text-body font-medium">{center.frictionValue}</span>
        </div>
        <div class="flex justify-between items-center border-t border-surface-white/20 pt-4">
          <span class="am-text-caption uppercase tracking-wider text-faint">{carAccessLabel}</span>
          <span class="am-text-body font-medium">{center.carAccessValue}</span>
        </div>
      </div>
    </div>

    <div class="border border-surface-container-high bg-surface-white p-8 flex flex-col h-full">
      <div class="mb-8">
        <Car className="w-6 h-6 text-on-surface mb-4" strokeWidth={1.5} />
        <h3 class="am-text-subtitle mb-2">{right.title}</h3>
        <p class="am-text-body text-on-surface-variant font-light">{right.description}</p>
      </div>
      <div class="mt-auto space-y-4">
        <div class="flex justify-between items-center border-t border-surface-container-high pt-4">
          <span class="am-text-caption uppercase tracking-wider text-muted">{frictionLabel}</span>
          <span class="am-text-body font-medium">{right.frictionValue}</span>
        </div>
        <div class="flex justify-between items-center border-t border-surface-container-high pt-4">
          <span class="am-text-caption uppercase tracking-wider text-muted">{carAccessLabel}</span>
          <span class="am-text-body font-medium">{right.carAccessValue}</span>
        </div>
      </div>
    </div>
  </div>
</section>
