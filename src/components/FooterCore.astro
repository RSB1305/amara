---
import { normalizeLanguage } from '../lib/seo/resolve-seo-head';
import { resolveLink } from '../lib/linkResolver';
import type { AmaraLanguage } from '../types/seo';

const pathname = Astro.url.pathname;
const rawLang = pathname.split('/')[1] || 'es';
const currentLang: AmaraLanguage = normalizeLanguage(rawLang);
---

<footer class="footer-core border-t border-outline-variant/10 bg-surface-container-lowest px-12 py-12">
  <div class="max-w-screen-2xl mx-auto">
    <div class="footer-core__utility flex flex-wrap items-start justify-between gap-8 border-b border-outline-variant/10 pb-8">
      <div class="footer-core__social flex flex-wrap items-center gap-x-4 gap-y-2 font-label text-[11px] font-bold uppercase tracking-[0.14em] text-on-surface-variant">
        <span>&copy; 2026 AMARA</span>
        <span>Frigiliana, Malaga &middot; Spain</span>
      </div>

      <div class="footer-core__contact flex flex-wrap items-center gap-x-8 gap-y-3">
        <a href="tel:+34604440964" class="font-label text-[11px] font-bold uppercase tracking-[0.14em] text-on-surface-variant hover:text-primary transition-colors">
          +34 604 440 964
        </a>
        <a href="mailto:hola@amara-lodging.es" class="font-label text-[11px] font-bold uppercase tracking-[0.14em] text-on-surface-variant hover:text-primary transition-colors">
          hola@amara-lodging.es
        </a>
      </div>

      <div class="footer-core__right flex flex-wrap items-center gap-x-4 gap-y-2">
        <a href={resolveLink('legal_notice', currentLang)} class="font-label text-[11px] font-bold uppercase tracking-[0.14em] text-on-surface-variant hover:text-primary transition-colors">
          Legal Notice
        </a>
        <span class="font-label text-[11px] font-bold uppercase tracking-[0.14em] text-outline">&middot;</span>
        <a href={resolveLink('legal_notice', currentLang)} class="font-label text-[11px] font-bold uppercase tracking-[0.14em] text-on-surface-variant hover:text-primary transition-colors">
          Privacy
        </a>
      </div>
    </div>
  </div>
</footer>
