---
/**
 * On-page section anchor navigation (Type A and similar long pages).
 * Local content nav only — not a substitute for the global main navigation.
 */
export interface SectionAnchorNavItem {
  label: string;
  href: string;
  id?: string;
}

interface Props {
  items: SectionAnchorNavItem[];
  activeId?: string;
}

const { items, activeId } = Astro.props;
---

<nav
  class="border-b border-outline-variant/5 bg-transparent"
  aria-label="On this page"
>
  <div class="max-w-screen-2xl mx-auto px-12 py-3">
    <ul
      class="-mx-1 flex flex-nowrap items-center gap-3 overflow-x-auto overscroll-x-contain py-1 md:flex-wrap md:justify-center md:overflow-visible"
    >
      {
        items.map((item) => (
          <li class="shrink-0">
            <a
              href={item.href}
              class:list={[
                'inline-flex items-center whitespace-nowrap rounded-full border px-4 py-2 text-[11px] font-label font-bold uppercase tracking-[0.14em] transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/25 focus-visible:ring-offset-2',
                item.id && activeId && item.id === activeId
                  ? 'border-outline-variant/20 bg-surface/80 text-on-surface'
                  : 'border-outline-variant/10 bg-surface/40 text-on-surface-variant hover:bg-surface/70 hover:text-on-surface'
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>
