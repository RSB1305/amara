---
/**
 * EditorialDefinitionList
 *
 * Two-column definition rows (title + description) with a strong top rule.
 */
export interface EditorialDefinitionListItem {
  title: string;
  description: string;
}

interface Props {
  items: EditorialDefinitionListItem[];
}

const { items } = Astro.props;
---

<div class="border-t-2 border-on-surface">
  {
    items.map((item) => (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 py-8 border-b border-on-surface/10">
        <h3 class="font-body font-semibold text-lg text-on-surface m-0">{item.title}</h3>
        <p class="font-body text-on-surface-variant m-0">{item.description}</p>
      </div>
    ))
  }
</div>
