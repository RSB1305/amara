---
/**
 * SustainabilityBand
 *
 * Full-bleed green editorial band with headline, lead, and two-column checklist lists.
 */
export interface SustainabilityListColumn {
  label: string;
  items: string[];
}

interface Props {
  title: string;
  subtitle: string;
  lead: string;
  listColumns: SustainabilityListColumn[];
}

const { title, subtitle, lead, listColumns } = Astro.props;
---

<section
  class="am-exp-section bg-[#dcefe6] text-[#1d3128] py-[clamp(4rem,8vw,8rem)] px-[clamp(2rem,5vw,5rem)] -mx-[5vw] mb-[clamp(8rem,15vw,14rem)]"
>
  <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-[clamp(4rem,8vw,8rem)]">
    <header class="flex flex-col gap-2">
      <h2 class="am-section-title !text-[#1d3128]">{title}</h2>
      <p class="am-kicker opacity-70">{subtitle}</p>
    </header>
    <div>
      <p class="font-body text-[clamp(1.25rem,2vw,1.5rem)] leading-[1.5] text-[#1d3128] mb-8 m-0">
        {lead}
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mt-16">
        {
          listColumns.map((column) => (
            <div>
              <h3 class="font-body text-xs font-semibold uppercase tracking-[0.1em] text-[#1d3128]/70 mb-6 pb-2 border-b border-[#1d3128]/18 m-0">
                {column.label}
              </h3>
              <ul class="list-none p-0 m-0 font-body text-[#1d3128]">
                {column.items.map((item) => (
                  <li class="relative mb-3 pl-5 last:mb-0 before:content-['—'] before:absolute before:left-0 before:opacity-40">
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
