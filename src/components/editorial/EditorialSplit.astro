---
/**
 * EditorialSplit
 *
 * Two-column editorial layout: sticky headline left, prose slot right.
 * Replaces legacy .am-exp-grid-split patterns on trust pages.
 */
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-[1.2fr_1.8fr] gap-[clamp(3rem,8vw,8rem)]">
  <div class="relative">
    <h2 class="font-headline text-4xl md:text-5xl text-on-surface md:sticky md:top-8">{title}</h2>
  </div>
  <div class="flex max-w-[65ch] flex-col gap-6">
    <slot />
  </div>
</div>
