---
/**
 * EditorialFeatureGrid
 *
 * Responsive feature cards with labeled headers and body copy (quality / amenity grids).
 */
export interface EditorialFeatureCard {
  title: string;
  subline?: string;
  copy: string;
}

interface Props {
  cards: EditorialFeatureCard[];
}

const { cards } = Astro.props;
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-16">
  {
    cards.map((card) => (
      <div>
        <div class="min-h-[4rem] mb-4 pb-2 border-b border-on-surface/10 flex items-start">
          <h3 class="font-body font-semibold text-base uppercase tracking-wider leading-tight text-on-surface m-0">
            {card.title}
            {card.subline ? (
              <span class="block text-hint font-normal normal-case tracking-normal mt-1">{card.subline}</span>
            ) : null}
          </h3>
        </div>
        <p class="font-body text-on-surface-variant m-0">{card.copy}</p>
      </div>
    ))
  }
</div>
