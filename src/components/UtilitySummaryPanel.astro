---
export interface UtilityItem {
  label: string;
  value: string | string[];
  note?: string;
}

export interface Props {
  title?: string;
  items: UtilityItem[];
}

const { title, items } = Astro.props;
---

<aside class="am-utility-panel">
  {title && <h3 class="am-section-title am-utility-panel__title">{title}</h3>}
  
  <dl class="am-utility-panel__list">
    {items.map((item) => (
      <div class="am-utility-panel__item">
        <dt class="am-kicker am-utility-panel__label">{item.label}</dt>
        <dd class="am-utility-panel__value">
          {Array.isArray(item.value) ? (
            item.value.map((line) => <span class="am-body am-utility-panel__value-line">{line}</span>)
          ) : (
            <span class="am-body am-utility-panel__value-line">{item.value}</span>
          )}
          {item.note && <p class="am-body am-utility-panel__note">{item.note}</p>}
        </dd>
      </div>
    ))}
  </dl>
</aside>

<style>
  .am-utility-panel {
    background-color: rgba(0, 0, 0, 0.02);
    border: 1px solid rgba(0, 0, 0, 0.04);
    padding: clamp(1.5rem, 4vw, 2.5rem);
  }

  .am-utility-panel__title {
    font-size: 1.5rem;
    margin-top: 0;
    margin-bottom: 2rem;
  }

  .am-utility-panel__list {
    display: flex;
    flex-direction: column;
    margin: 0;
    padding: 0;
  }

  .am-utility-panel__item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1.25rem 0;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .am-utility-panel__item:first-child {
    padding-top: 0;
    border-top: none;
  }

  .am-utility-panel__item:last-child {
    padding-bottom: 0;
  }

  .am-utility-panel__label {
    margin: 0 0 0.25rem 0;
    opacity: 0.6;
  }

  .am-utility-panel__value {
    margin: 0;
  }

  .am-utility-panel__value-line {
    display: block;
    line-height: 1.4;
  }

  .am-utility-panel__note {
    font-size: 0.85em;
    opacity: 0.7;
    margin: 0.5rem 0 0 0;
  }
</style>
