---
/**
 * AMARA — Global Back-to-Top control
 *
 * Architectural intent:
 * This component provides one single, shared back-to-top interaction
 * across the entire site. It is intentionally implemented as a global
 * UI utility rather than a footer-specific element so behavior and
 * styling remain consistent on desktop and mobile.
 */
---

<button
  class="am-back-to-top"
  type="button"
  aria-label="Back to top"
  data-am-back-to-top
>
  <svg
    class="am-back-to-top__icon"
    viewBox="0 0 24 24"
    aria-hidden="true"
    focusable="false"
  >
    <path
      d="M6 14l6-6 6 6"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
  </svg>
</button>

<script>
  /**
   * AMARA — shared visibility + scroll behavior
   *
   * Why this exists:
   * A lightweight inline script keeps the component self-contained and
   * avoids introducing a parallel client utility for a very small
   * interaction. The control stays hidden until the user has scrolled
   * enough for the action to become useful.
   */
  document.addEventListener('DOMContentLoaded', () => {
    const button = document.querySelector('[data-am-back-to-top]');
    if (!button) return;

    const toggleVisibility = () => {
      const shouldShow = window.scrollY > 500;
      button.classList.toggle('is-visible', shouldShow);
    };

    button.addEventListener('click', () => {
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    });

    toggleVisibility();
    window.addEventListener('scroll', toggleVisibility, { passive: true });
  });
</script>

<style>
  .am-back-to-top {
    position: fixed;
    right: 20px;
    bottom: 20px;
    z-index: 1400;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid rgba(0, 0, 0, 0.14);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.96);
    color: #1f1f1f;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    cursor: pointer;
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    pointer-events: none;
    transition:
      opacity 180ms ease,
      transform 180ms ease,
      visibility 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
    -webkit-tap-highlight-color: transparent;
  }

  .am-back-to-top.is-visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  .am-back-to-top:hover {
    border-color: rgba(0, 0, 0, 0.22);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.16);
  }

  .am-back-to-top:focus-visible {
    outline: none;
    border-color: rgba(0, 0, 0, 0.32);
    box-shadow:
      0 0 0 3px rgba(0, 0, 0, 0.08),
      0 10px 28px rgba(0, 0, 0, 0.16);
  }

  .am-back-to-top__icon {
    width: 18px;
    height: 18px;
  }

  @media (max-width: 767px) {
    .am-back-to-top {
      right: 16px;
      bottom: 16px;
      width: 42px;
      height: 42px;
      border-radius: 10px;
    }

    .am-back-to-top__icon {
      width: 17px;
      height: 17px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .am-back-to-top {
      transition: none;
    }
  }
</style>
