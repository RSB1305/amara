---
// src/components/StayDecision.astro
/**
 * AMARA v3 StayDecision (Type A Authority)
 * Fokus: Klärung der Eignung (Alltagstauglichkeit & Profile).
 */
interface Profile {
  title: string;
  description: string;
  suitability: string; // z.B. "High", "Moderate", "Challenging"
}

interface Props {
  eyebrow: string;
  title: string;
  profiles: Profile[];
}

const { eyebrow, title, profiles } = Astro.props;
---

<section class="max-w-screen-2xl mx-auto px-12 py-40 border-t border-outline-variant/5">
  <div class="mb-20">
    <span class="label-md uppercase tracking-[0.4em] text-[10px] text-primary font-bold block mb-6">{eyebrow}</span>
    <h2 class="text-5xl font-headline italic text-on-surface tracking-tight">{title}</h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
    {profiles.map((profile) => (
      <div class="flex flex-col border-l border-outline-variant/20 pl-8 py-4">
        <div class="flex justify-between items-start mb-6">
          <h3 class="text-2xl font-headline italic text-on-surface">{profile.title}</h3>
          <span class="text-[9px] uppercase tracking-widest font-bold text-primary bg-primary-container/20 px-2 py-1">
            {profile.suitability}
          </span>
        </div>
        <p class="text-on-surface-variant text-base leading-relaxed font-body opacity-80">
          {profile.description}
        </p>
      </div>
    ))}
  </div>
</section>