---
interface HeroLink {
  href: string;
  label: string;
}

interface Props {
  title: string;
  subtitle?: string;
  lead: string;
  ctaLinks?: HeroLink[];
  supportText?: string;
}

const { title, subtitle, lead, ctaLinks = [], supportText } = Astro.props;
---

<header class="am-exp-hero">
  {subtitle && (
    <div class="am-exp-hero__meta">
      <span class="am-kicker am-gold">{subtitle}</span>
    </div>
  )}
  <h1 class="am-exp-hero__title" set:html={title} />
  <p class="am-exp-hero__lead">{lead}</p>
  {supportText && <p class="am-hero-support">{supportText}</p>}
  {ctaLinks.length > 0 && (
    <div class="am-cta-group am-cta-group--left mt-8">
      {ctaLinks.map((link, index) => (
        <>
          {index > 0 && <span class="am-exp-cta__dot">&middot;</span>}
          <a href={link.href} class="am-cta-link">
            {link.label}
          </a>
        </>
      ))}
    </div>
  )}
</header>

<style>
  @reference "../../styles/global.css";

  .am-exp-hero {
    padding: clamp(2rem, 4vw, 2.5rem) 0 clamp(4rem, 8vw, 8rem);
  }

  .am-exp-hero__meta {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 3rem;
    opacity: 0.6;
  }

  .am-exp-hero__title {
    font-family: "Newsreader", serif;
    font-size: clamp(3.5rem, 7vw, 6rem);
    line-height: 1.05;
    font-weight: 300;
    letter-spacing: -0.02em;
    @apply text-on-surface;
    max-width: 12ch;
    margin: 0 0 2.5rem 0;
  }

  @media (min-width: 1024px) {
    .am-exp-hero__title {
      max-width: 18ch;
    }
  }

  .am-exp-hero__lead {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    line-height: 1.6;
    @apply text-subtle;
    max-width: 35ch;
  }

  .am-hero-support {
    margin-top: 1.5rem;
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 0.95rem;
    line-height: 1.6;
    @apply text-muted;
    font-style: italic;
  }

</style>
