---
// src/components/EssenceGrid.astro
/**
 * AMARA v3 EssenceGrid (Bento-System)
 * Governance: Rein visuelle Strukturkomponente.
 * Keine Logik, keine Sprache, kein Routing.
 */
interface GridItem {
  kicker: string;
  headline: string;
  text: string;
  imageSrc?: string;
  imageAlt?: string;
  href?: string;
  linkLabel?: string;
}

interface Props {
  eyebrow: string;
  title: string;
  intro: string;
  items: GridItem[];
}

const { eyebrow, title, intro, items } = Astro.props;
---

<section class="max-w-screen-2xl mx-auto px-12 py-40 border-t border-outline-variant/5">
  <div class="max-w-3xl mb-24">
    <span class="am-text-caption uppercase tracking-[0.4em] text-primary mb-6 block">
      {eyebrow}
    </span>
    <h2 class="am-text-display italic text-on-surface mb-8 tracking-tight leading-[1.1]">
      {title}
    </h2>
    <p class="am-text-body text-on-surface-variant opacity-80 italic leading-relaxed">
      {intro}
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-4 md:grid-rows-2 gap-8 h-auto md:h-[900px]">
    {items && items.length >= 4 && (
      <>
        <div class="md:col-span-2 md:row-span-2 relative group overflow-hidden bg-surface-container-low flex flex-col justify-end p-12">
          {items[0].imageSrc && (
            <img
              src={items[0].imageSrc}
              alt={items[0].imageAlt || ''}
              class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-1000 ease-out opacity-60"
            />
          )}
          <div class="relative z-10">
            <span class="am-text-caption uppercase tracking-[0.3em] text-primary block mb-4">{items[0].kicker}</span>
            <h3 class="am-text-title italic text-on-surface mb-6 leading-tight">{items[0].headline}</h3>
            <p class="am-text-body text-on-surface-variant leading-relaxed max-w-md mb-8">{items[0].text}</p>
            {items[0].linkLabel &&
              (items[0].href ? (
                <a
                  href={items[0].href}
                  class="inline-block am-text-caption uppercase tracking-[0.3em] text-primary border-b border-primary/30 pb-1 hover:border-primary transition-colors"
                >
                  {items[0].linkLabel}
                </a>
              ) : (
                <span class="am-link-disabled inline-block am-text-caption uppercase tracking-[0.3em] text-primary border-b border-primary/30 pb-1 transition-colors">
                  {items[0].linkLabel}
                </span>
              ))}
          </div>
        </div>

        <div class="md:col-span-2 bg-on-surface p-12 flex flex-col justify-center text-surface">
          <span class="am-text-caption uppercase tracking-[0.3em] text-primary-fixed-dim block mb-4">{items[1].kicker}</span>
          <h3 class="am-text-title italic mb-6 leading-tight">{items[1].headline}</h3>
          <p class="am-text-body text-surface/70 leading-relaxed max-w-md">{items[1].text}</p>
        </div>

        <div class="md:col-span-1 bg-surface-container flex flex-col p-8 justify-between border border-outline-variant/10">
          <div>
            <span class="am-text-caption uppercase tracking-[0.3em] text-outline block mb-4">{items[2].kicker}</span>
            <h3 class="am-text-subtitle italic text-on-surface leading-tight mb-4">{items[2].headline}</h3>
          </div>
          <p class="am-text-body text-on-surface-variant leading-relaxed">{items[2].text}</p>
        </div>

        <div class="md:col-span-1 relative overflow-hidden bg-primary-container p-8 flex flex-col justify-end group">
          {items[3].imageSrc && (
            <img
              src={items[3].imageSrc}
              alt={items[3].imageAlt || ''}
              class="absolute inset-0 w-full h-full object-cover opacity-20 group-hover:scale-110 transition-transform duration-1000"
            />
          )}
          <div class="relative z-10">
            <h3 class="am-text-subtitle italic text-on-primary-container leading-tight mb-4">{items[3].headline}</h3>
            <p class="am-text-caption uppercase tracking-widest leading-loose text-on-primary-container/80">{items[3].text}</p>
          </div>
        </div>
      </>
    )}
  </div>
</section>

<style>
  .am-link-disabled {
    pointer-events: none;
    cursor: default;
    opacity: 0.6;
  }
</style>
