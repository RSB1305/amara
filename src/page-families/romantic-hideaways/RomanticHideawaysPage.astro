---
/**
 * AMARA Romantic Hideaways — collection landing (from AI Studio import).
 * Shell: BaseLayout + Navigation + single .am-root > .am-wrap.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import TrustHero from '../../components/hero/TrustHero.astro';
import ApartmentCard from '../../components/location/ApartmentCard.astro';
import ApartmentGrid from '../../components/location/ApartmentGrid.astro';
import GuestReviewsSummary from '../../components/location/GuestReviewsSummary.astro';
import { resolveLink } from '../../lib/linkResolver';
import { normalizeLanguage } from '../../lib/seo/resolve-seo-head';
import type { AmaraAuthoringSeo, AmaraLanguage } from '../../types/seo';

interface Props {
  lang?: string;
}

const { lang = 'es' } = Astro.props;
const currentLang = normalizeLanguage(lang as AmaraLanguage);

const seo: AmaraAuthoringSeo = {
  version: '2026-04-04-romantic-hideaways-v1.0-C',
  pageType: 'C',
  entityKey: 'amara-brand',
  languages: {
    en: {
      title: 'AMARA Romantic Hideaways | Boutique Stays in Frigiliana & Nerja',
      description:
        'Design-led boutique apartments for couples in Frigiliana and Nerja — curated hosting, verified guest love, direct booking.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    de: {
      title: 'AMARA Romantic Hideaways | Boutique-Unterkünfte in Frigiliana & Nerja',
      description:
        'Design-geführte Boutique-Apartments für Paare in Frigiliana und Nerja — kuratiertes Hosting, verifizierte Gästeliebe, Direktbuchung.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    es: {
      title: 'AMARA Romantic Hideaways | Estancias boutique en Frigiliana y Nerja',
      description:
        'Apartamentos boutique para parejas en Frigiliana y Nerja — hospitalidad curada, reseñas verificadas, reserva directa.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    nl: {
      title: 'AMARA Romantic Hideaways | Boutiqueverblijven in Frigiliana & Nerja',
