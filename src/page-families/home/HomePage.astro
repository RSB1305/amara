---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import HomeCinematicMain from '../../components/home/HomeCinematicMain.tsx';
import { resolveLink } from '../../lib/linkResolver';
import { normalizeLanguage } from '../../lib/seo/resolve-seo-head';
import type { AmaraAuthoringSeo, AmaraLanguage } from '../../types/seo';
import {
  cinematicApartments,
  cinematicHeroKicker,
  cinematicHeroLead,
  cinematicScrollHint,
  cinematicPhilosophyPart1,
  cinematicPhilosophyAccent,
  cinematicPhilosophyLabel,
  cinematicPhilosophyP1,
  cinematicPhilosophyP2,
  cinematicCollectionEyebrow,
  cinematicCollectionTitle,
  cinematicTrustQuote,
  cinematicTrustCta,
  cinematicTrustChips,
  cinematicStatReviewsValue,
  cinematicStatRatingValue,
  cinematicStatReviewsLabel,
  cinematicStatRatingLabel,
  navExperiences,
  navSoonBadge
} from '../../content/homeCinematicCopy';

const HERO_IMG = 'https://l.icdbcdn.com/oh/882b7732-0b8a-4d00-b9af-16271f78d09e.jpg';
const TRUST_BG = 'https://l.icdbcdn.com/oh/392c7773-50bf-4814-955d-da26457f6440.jpg';

interface Props {
  lang?: string;
}

const { lang = 'es' } = Astro.props;
const currentLang = normalizeLanguage(lang as AmaraLanguage);

const t = <T extends Record<AmaraLanguage, string>>(row: T) => row[currentLang] ?? row.en;

const seo: AmaraAuthoringSeo = {
  version: '2026-04-04-amara-home-cinematic-v3.0-A',
  pageType: 'A',
  languages: {
    en: {
      title: 'AMARA | Boutique Holiday Apartments in Frigiliana & Nerja',
      description:
        'Premium holiday homes in Andalusia. Quiet stays, direct host contact, and curated comfort in Frigiliana and Nerja.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    de: {
      title: 'AMARA | Boutique-Ferienwohnungen in Frigiliana & Nerja',
      description:
        'Premium-Unterkünfte in Andalusien: ruhige Aufenthalte, direkter Gastgeberkontakt und kuratierte Ausstattung in Frigiliana und Nerja.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    es: {
      title: 'AMARA | Apartamentos boutique en Frigiliana y Nerja',
      description:
        'Casas de vacaciones premium en Andalucía: estancias tranquilas, contacto directo con el anfitrión y confort cuidado en Frigiliana y Nerja.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    nl: {
      title: 'AMARA | Boutique vakantieappartementen in Frigiliana & Nerja',
      description:
        'Premium vakantieverblijven in Andalusië: rustige verblijven, direct contact met de gastheer en zorgvuldig comfort in Frigiliana en Nerja.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    sv: {
      title: 'AMARA | Boutique-lägenheter i Frigiliana & Nerja',
      description:
        'Premium semesterboenden i Andalusien: lugna vistelser, direkt kontakt med värden och omsorgsfullt komfort i Frigiliana och Nerja.',
      robots: 'index, follow',
      canonical: 'auto'
    }
  }
};

const homeNavLinks = [
  { token: 'location_frigiliana', label: 'Frigiliana' },
  { token: 'location_nerja', label: 'Nerja', disabled: true },
  { token: 'location_tarifa', label: 'Tarifa', disabled: true },
  { token: 'explore_hub', label: t(navExperiences), forceEnabled: true }
];

const cinematicApartmentsProps = cinematicApartments.map((apt) => ({
  id: apt.id,
  name: apt.name,
  subtitle: t(apt.subtitle),
  meta: t(apt.meta),
  desc: t(apt.desc),
  img: apt.img,
  exploreHref: resolveLink(apt.token, currentLang),
  exploreLabel: t(apt.exploreLabel)
}));
---

<BaseLayout seo={seo} pageLang={currentLang}>
  <Navigation
    currentLang={currentLang}
    brandName="AMARA"
    links={homeNavLinks}
    variant="default"
    languageToken="home"
    comingSoonBadge={t(navSoonBadge)}
  />
  <div class="am-root" data-am-page="home">
    <div class="am-wrap w-full max-w-screen-2xl mx-auto px-6 md:px-12 pb-20">
      <HomeCinematicMain
        client:load
        heroImageSrc={HERO_IMG}
        heroKicker={t(cinematicHeroKicker)}
        heroLead={t(cinematicHeroLead)}
        scrollHint={t(cinematicScrollHint)}
        philosophyHeadlinePart1={t(cinematicPhilosophyPart1)}
        philosophyHeadlineAccent={t(cinematicPhilosophyAccent)}
        philosophyLabel={t(cinematicPhilosophyLabel)}
        philosophyP1={t(cinematicPhilosophyP1)}
        philosophyP2={t(cinematicPhilosophyP2)}
        statReviewsValue={cinematicStatReviewsValue}
        statRatingValue={cinematicStatRatingValue}
        statReviewsLabel={t(cinematicStatReviewsLabel)}
        statRatingLabel={t(cinematicStatRatingLabel)}
        collectionEyebrow={t(cinematicCollectionEyebrow)}
        collectionTitle={t(cinematicCollectionTitle)}
        apartments={cinematicApartmentsProps}
        trustBgSrc={TRUST_BG}
        trustQuote={t(cinematicTrustQuote)}
        trustChips={cinematicTrustChips[currentLang]}
        trustCta={t(cinematicTrustCta)}
        trustReviewsHref={resolveLink('reviews_hub', currentLang)}
      />
    </div>
  </div>
</BaseLayout>
