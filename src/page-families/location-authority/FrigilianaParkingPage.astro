  pageType: 'A',
  entityKey: 'amara-brand',
  languages: {
    en: {
      title: 'Parking & movement in Frigiliana | AMARA Location Guide',
      description:
        'How parking and walking really work in a vertical hill village — and how your choice of base shapes daily rhythm.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    de: {
      title: 'Parken und Bewegung in Frigiliana | AMARA Ortsguide',
      description:
        'Wie Parken und Gehen in einem steilen Bergdorf wirklich funktionieren — und wie Ihre Basis den Tagesrhythmus prägt.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    es: {
      title: 'Aparcamiento y movimiento en Frigiliana | Guía AMARA',
      description:
        'Cómo funcionan de verdad aparcar y caminar en un pueblo en cuesta — y cómo vuestra base marca el ritmo del día.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    nl: {
      title: 'Parkeren en bewegen in Frigiliana | AMARA locatiegids',
      description:
        'Hoe parkeren en lopen in een hellend dorp echt werkt — en hoe uw uitvalsbasis het dagritme bepaalt.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    sv: {
      title: 'Parkering och rörelse i Frigiliana | AMARA platsguide',
      description:
        'Hur parkering och promenader verkligen fungerar i en brant by — och hur er bas formar vardagsrytmen.',
      robots: 'index, follow',
      canonical: 'auto'
    }
  }
};

/** Mirrors authoring SEO for consumers that read data-amara="seo" (in addition to BaseLayout data-amara-system). */
