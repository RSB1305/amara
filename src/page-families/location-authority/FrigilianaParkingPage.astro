  header: {
    eyebrow: t(copy.header.eyebrow),
    h1Html: t(copy.header.h1Html),
    lead: t(copy.header.lead),
    backLinkWord: t(copy.header.backLinkWord)
  },
  decision: {
    title: t(copy.decision.title),
    shortLabel: t(copy.decision.shortLabel),
    shortBody: t(copy.decision.shortBody),
    variableLabel: t(copy.decision.variableLabel),
    variableBody: t(copy.decision.variableBody)
