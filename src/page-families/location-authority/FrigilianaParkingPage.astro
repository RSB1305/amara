---
/**
 * Frigiliana Parking & movement (Type A / Location Authority)
 *
 * Uses ParkingRealityPillars + StayModels from components/location for the
 * “What Matters Most” and stay-model blocks (same structure as src/pages/test.astro inline block). Shell: single .am-root / .am-wrap.
 */
import LocationAuthorityLayout from '../../layouts/LocationAuthorityLayout.astro';
import Navigation from '../../components/Navigation.astro';
import SectionAnchorNav from '../../components/navigation/SectionAnchorNav.astro';
import SmartBackButton from '../../components/navigation/SmartBackButton.astro';
import ParkingRealityPillars from '../../components/location/ParkingRealityPillars.astro';
import StayModels from '../../components/location/StayModels.astro';
import { resolveLink } from '../../lib/linkResolver';
import { getFrigilianaAuthoritySubnav } from '../../lib/frigiliana/frigilianaAuthoritySubnav';
import { normalizeLanguage } from '../../lib/seo/resolve-seo-head';
import type { AmaraAuthoringSeo, AmaraLanguage } from '../../types/seo';

interface Props {
  lang?: string;
}

const { lang = 'es' } = Astro.props;
const currentLang = normalizeLanguage(lang as AmaraLanguage);
const sectionNavItems = getFrigilianaAuthoritySubnav(currentLang);

function t(row: Record<AmaraLanguage, string>): string {
  return row[currentLang] ?? row.en;
}

