const sectionLead = 'font-body text-on-surface-variant text-lg leading-relaxed italic max-w-3xl';
---

<LocationAuthorityLayout seo={seo} pageLang={currentLang} bodyBackgroundClass="bg-white">
  <Navigation
    currentLang={currentLang}
    brandName={c.nav.brand}
    links={c.nav.links}
    languageToken="frigiliana_parking"
    locationAuthorityNav={true}
  />
  <SectionAnchorNav items={sectionNavItems} activeId="arrival" />

  <div class="am-root" data-am-page="frigiliana-parking">
    <script type="application/json" data-amara="seo" set:html={seoAmaraJson} />

    <div class="am-wrap w-full max-w-screen-2xl mx-auto px-12 pt-20 pb-20">
      <SmartBackButton
        variant="link"
        label={c.header.backLinkWord}
        fallbackHref={resolveLink('location_frigiliana', currentLang)}
      />
      <header class="mb-20 border-b border-black/10 pb-12">
        <span class="label-md font-label text-primary mb-4 block">{c.header.eyebrow}</span>
        <h1 class="text-6xl font-headline italic text-on-surface mb-6" set:html={c.header.h1Html} />
        <p class="font-body text-on-surface-variant text-xl italic opacity-70 max-w-2xl">{c.header.lead}</p>
      </header>

      <div class="pt-8 space-y-20">
        <section class="space-y-8">
          <h2 class="text-3xl font-headline italic text-on-surface">{c.decision.title}</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div>
              <h3 class="font-label text-[10px] uppercase tracking-[0.18em] text-primary mb-4">
                {c.decision.shortLabel}
              </h3>
              <p class={`${sectionLead} mb-0`}>{c.decision.shortBody}</p>
            </div>
            <div>
              <h3 class="font-label text-[10px] uppercase tracking-[0.18em] text-primary mb-4">
                {c.decision.variableLabel}
              </h3>
              <p class={`${sectionLead} mb-0`}>{c.decision.variableBody}</p>
            </div>
          </div>
        </section>

        <ParkingRealityPillars
          title={c.parkingGrid.title}
          intro={c.parkingGrid.intro}
          items={[
            {
              title: c.parkingGrid.columns[0].title,
              text: c.parkingGrid.columns[0].body,
              icon: 'map-pin'
            },
            {
              title: c.parkingGrid.columns[1].title,
              text: c.parkingGrid.columns[1].body,
              icon: 'clock'
            },
            {
              title: c.parkingGrid.columns[2].title,
              text: c.parkingGrid.columns[2].body,
              icon: 'footprints'
            }
          ]}
        />

        <StayModels
          title={c.stayModels.title}
          intro={c.stayModels.intro}
          frictionLabel={c.stayModels.frictionLabel}
          carAccessLabel={c.stayModels.carAccessLabel}
          left={c.stayModels.left}
          center={c.stayModels.center}
          right={c.stayModels.right}
        />

        <section class="space-y-6">
          <span class="font-label text-[10px] uppercase tracking-[0.18em] text-primary block">{c.amara.eyebrow}</span>
          <h2 class="text-3xl font-headline italic text-on-surface">{c.amara.title}</h2>
          <p class={sectionLead}>{c.amara.body}</p>
          <p class="pt-2">
            <a href={resolveLink('book', currentLang)} class="am-cta-link">{c.amara.cta}</a>
          </p>
        </section>
      </div>
    </div>
  </div>
</LocationAuthorityLayout>
