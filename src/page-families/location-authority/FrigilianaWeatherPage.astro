        label: { en: 'Sun', de: 'Sonne', es: 'Sol', nl: 'Zon', sv: 'Sol' },
        value: { en: '300+ days', de: '300+ Tage', es: '300+ días', nl: '300+ dagen', sv: '300+ dagar' },
        note: {
          en: 'Bright light is a constant — plan shade for midday walks.',
          de: 'Helles Licht ist konstant — für Mittagswege Schatten einplanen.',
