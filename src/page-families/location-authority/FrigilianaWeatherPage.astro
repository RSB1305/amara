const t = <T extends Record<AmaraLanguage, string>>(row: T) => row[currentLang] ?? row.en;
---

<LocationAuthorityLayout seo={seo} pageLang={currentLang} bodyBackgroundClass="bg-white">
  <Navigation
    currentLang={currentLang}
    brandName={t(copy.nav.brand)}
    links={copy.nav.links.map((l) => ({ token: l.token, label: t(l.label) }))}
    languageToken="weather_frigiliana"
    locationAuthorityNav={true}
  />

  <SectionAnchorNav items={sectionNavItems} activeId="weather" />

  <div class="am-root" data-am-page="frigiliana-weather">
    <div class="am-wrap w-full max-w-screen-2xl mx-auto px-12 pt-20 pb-20">
      <SmartBackButton
        variant="link"
        label={t(copy.header.back)}
        fallbackHref={resolveLink('location_frigiliana', currentLang)}
      />

      <header class="mb-20 border-b border-black/10 pb-12">
        <span class="label-md font-label text-primary mb-4 block">{t(copy.header.eyebrow)}</span>
        <h1 class="text-6xl font-headline italic text-on-surface mb-6">{t(copy.header.h1)}</h1>
        <p class="font-body text-on-surface-variant text-xl italic opacity-70 max-w-2xl">{t(copy.header.lead)}</p>
      </header>

      <div class="pt-8 space-y-20">
        {/* 1) Weather at a Glance */}
        <section class="grid gap-10 lg:grid-cols-12 items-start">
          <div class="lg:col-span-8 space-y-6">
            <h2 class="text-3xl font-headline italic text-on-surface">{t(copy.glance.title)}</h2>
            <p class="font-body text-on-surface-variant text-lg leading-relaxed italic max-w-3xl">
              {t(copy.glance.intro)}
            </p>
          </div>
          <div class="lg:col-span-4 space-y-4">
            <HairlineStatCard
              label={t(copy.glance.stats.sun.label)}
              value={t(copy.glance.stats.sun.value)}
              description={t(copy.glance.stats.sun.note)}
            />
            <HairlineStatCard
              label={t(copy.glance.stats.evening.label)}
              value={t(copy.glance.stats.evening.value)}
              description={t(copy.glance.stats.evening.note)}
            />
            <HairlineStatCard
              label={t(copy.glance.stats.nights.label)}
              value={t(copy.glance.stats.nights.value)}
              description={t(copy.glance.stats.nights.note)}
            />
          </div>
        </section>

        {/* 2) The Frigiliana Pattern (AI Studio composition) */}
        <section>
          <div class="mb-12 max-w-2xl">
            <h2 class="text-3xl font-headline text-on-surface mb-4">{t(copy.pattern.title)}</h2>
            <p class="text-lg text-on-surface-variant leading-relaxed">
              {t(copy.pattern.body)}
            </p>
          </div>

          <div class="grid grid-cols-2 md:grid-cols-4 gap-10 md:gap-16">
            {(copy.pattern.facts.title[currentLang] ?? copy.pattern.facts.title.en).map((item) => (
              <div>
                <div class="h-px w-10 bg-outline-variant/25"></div>
                <div class="mt-4 font-label text-[10px] font-bold uppercase tracking-[0.18em] text-on-surface-variant/70">
                  {item.label}
                </div>
                <div class:list={[
                  'mt-2 font-headline tracking-tight text-on-surface',
                  item.emphasize ? 'text-[28px] font-semibold' : 'text-2xl'
                ]}>
                  {item.value}
                </div>
                <p class="mt-3 font-body text-sm leading-relaxed text-on-surface-variant/80 max-w-[44ch]">
                  {item.description}
                </p>
              </div>
            ))}
          </div>
        </section>

        {/* 3) Best Time to Stay (AI Studio composition) */}
        <section>
          <div class="mb-12 max-w-2xl">
            <h2 class="text-3xl font-headline text-on-surface mb-4">{t(copy.seasons.title)}</h2>
            <p class="text-lg text-on-surface-variant leading-relaxed">
              {t(copy.seasons.intro)}
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <SeasonalPillar
              eyebrow={currentLang === 'de' ? 'März – Mai' : currentLang === 'es' ? 'Marzo – mayo' : currentLang === 'nl' ? 'Maart – mei' : currentLang === 'sv' ? 'Mars – maj' : 'March - May'}
              title={currentLang === 'de' ? 'Frühling' : currentLang === 'es' ? 'Primavera' : currentLang === 'nl' ? 'Lente' : currentLang === 'sv' ? 'Vår' : 'Spring'}
              subtitle={currentLang === 'de' ? 'Erwachen & Wildblumen' : currentLang === 'es' ? 'Despertar y flores' : currentLang === 'nl' ? 'Ontwaken & wilde bloemen' : currentLang === 'sv' ? 'Uppvaknande & vildblommor' : 'Awakening & Wildflowers'}
              highTemp="22°C"
              lowTemp="12°C"
              vibe={currentLang === 'de'
                ? 'Kühle Morgen und warme, helle Nachmittage. Das Tal ist grün — ideal für lange Wanderungen im Naturpark, bevor Sie den Abend auf der Terrasse ausklingen lassen.'
                : currentLang === 'es'
                  ? 'Mañanas frescas y tardes cálidas y luminosas. El valle está verde: ideal para caminatas largas antes de volver a la terraza.'
                  : currentLang === 'nl'
                    ? 'Frisse ochtenden en warme, heldere middagen. De vallei is groen: perfect voor lange wandelingen en daarna ontspanning op het terras.'
                    : currentLang === 'sv'
                      ? 'Krispiga morgnar och varma, ljusa eftermiddagar. Dalen är grön — perfekt för långa vandringar innan terrassen.'
                      : 'Crisp mornings and warm, bright afternoons. The valley turns lush — perfect for long hikes before relaxing on the terrace.'}
              hint={currentLang === 'de'
                ? 'Schichten einpacken; abends liegt noch ein leichter Bergkühlhauch in der Luft.'
                : currentLang === 'es'
                  ? 'Capas: por la noche aún refresca un poco.'
                  : currentLang === 'nl'
                    ? 'Laagjes: ’s avonds zit er nog een lichte bergkoelte.'
                    : currentLang === 'sv'
                      ? 'Packa lager; kvällar kan fortfarande vara svala.'
                      : 'Pack layers; evenings still carry a slight mountain chill.'}
            />
            <SeasonalPillar
              eyebrow={currentLang === 'de' ? 'Juni – August' : currentLang === 'es' ? 'Junio – agosto' : currentLang === 'nl' ? 'Juni – augustus' : currentLang === 'sv' ? 'Juni – augusti' : 'June - August'}
              title={currentLang === 'de' ? 'Sommer' : currentLang === 'es' ? 'Verano' : currentLang === 'nl' ? 'Zomer' : currentLang === 'sv' ? 'Sommar' : 'Summer'}
              subtitle={currentLang === 'de' ? 'Lange Sonne & kühle Nächte' : currentLang === 'es' ? 'Sol largo y noches frescas' : currentLang === 'nl' ? 'Lange zon & koelere nachten' : currentLang === 'sv' ? 'Lång sol & svala nätter' : 'Long Sun & Cool Nights'}
              highTemp="31°C"
              lowTemp="19°C"
              vibe={currentLang === 'de'
                ? 'Echte mediterrane Wärme am Tag — doch die Höhenlage bringt am Abend oft eine leichte Brise, die an der Küste fehlt. Ideal für langsame Morgen und späte Abendessen.'
                : currentLang === 'es'
                  ? 'Calor mediterráneo de día, pero al atardecer suele llegar una brisa suave que en la costa se nota menos. Perfecto para mañanas lentas y cenas tardías.'
