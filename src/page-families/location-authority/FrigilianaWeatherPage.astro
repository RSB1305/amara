import { resolveLink } from '../../lib/linkResolver';
import { getFrigilianaAuthoritySubnav } from '../../lib/frigiliana/frigilianaAuthoritySubnav';
import { normalizeLanguage } from '../../lib/seo/resolve-seo-head';
import type { AmaraAuthoringSeo, AmaraLanguage } from '../../types/seo';

interface Props {
  lang?: string;
}

const { lang = 'es' } = Astro.props;
const currentLang = normalizeLanguage(lang as AmaraLanguage);
const sectionNavItems = getFrigilianaAuthoritySubnav(currentLang);
const locationBase = resolveLink('location_frigiliana', currentLang);

const seo: AmaraAuthoringSeo = {
  version: '2026-04-01-frigiliana-weather-v1.0-A',
  pageType: 'A',
  entityKey: 'amara-brand',
  languages: {
    en: {
      title: 'Weather & Climate in Frigiliana | AMARA Location Guide',
      description:
        'How Frigiliana’s hillside microclimate changes evenings, sleep comfort, and walking rhythm — and when it feels especially breathable.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    de: {
      title: 'Wetter & Klima in Frigiliana | AMARA Ortsguide',
      description:
        'Wie Frigilianas Hanglage Abende, Schlafkomfort und Gehrhythmus prägt — und wann es sich besonders angenehm anfühlt.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    es: {
      title: 'Tiempo y clima en Frigiliana | Guía AMARA',
      description:
        'Cómo el microclima en ladera cambia las tardes, el descanso nocturno y el ritmo de caminar — y cuándo se siente más respirable.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    nl: {
      title: 'Weer & klimaat in Frigiliana | AMARA locatiegids',
      description:
        'Hoe Frigiliana’s microklimaat op de heuvel avonden, slaapcomfort en loopritme beïnvloedt — en wanneer het extra aangenaam voelt.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    sv: {
      title: 'Väder & klimat i Frigiliana | AMARA platsguide',
      description:
        'Hur Frigilianas microklimat på höjden påverkar kvällar, sömnkomfort och promenadrytm — och när det känns extra behagligt.',
      robots: 'index, follow',
      canonical: 'auto'
    }
  }
};

const copy = {
  nav: {
    brand: { en: 'Frigiliana', de: 'Frigiliana', es: 'Frigiliana', nl: 'Frigiliana', sv: 'Frigiliana' },
    links: [
      { token: 'location_frigiliana', label: { en: 'Frigiliana', de: 'Frigiliana', es: 'Frigiliana', nl: 'Frigiliana', sv: 'Frigiliana' } },
      { token: 'location_nerja', label: { en: 'Nerja', de: 'Nerja', es: 'Nerja', nl: 'Nerja', sv: 'Nerja' } },
      {
        token: 'explore_hub',
