---
import LocationAuthorityLayout from '../../layouts/LocationAuthorityLayout.astro';
import Navigation from '../../components/Navigation.astro';
import SectionAnchorNav from '../../components/navigation/SectionAnchorNav.astro';
import SmartBackButton from '../../components/navigation/SmartBackButton.astro';
import HairlineStatCard from '../../components/location/HairlineStatCard.astro';
