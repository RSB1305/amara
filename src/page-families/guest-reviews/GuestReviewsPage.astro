---

<BaseLayout seo={seo} footerHighlights={footerHighlights}>
  <Navigation
    currentLang={currentLang}
    brandName="AMARA"
    links={trustLinks}
    variant="trust"
    languageToken="reviews_hub"
  />
  <div class="am-root bg-white" data-am-page="guest-reviews">
    <div class="am-wrap w-full max-w-[1400px] mx-auto px-[5vw]">
    <TrustHero
      subtitle={copy.hero.subtitle[currentLang]}
      title={copy.hero.title[currentLang]}
      lead={copy.hero.lead[currentLang]}
      supportText={copy.hero.supportText[currentLang]}
      ctaLinks={[
        { href: resolveLink('about', currentLang), label: copy.hero.ctaAbout[currentLang] },
        { href: resolveLink('direct_booking_benefits', currentLang), label: copy.hero.ctaBenefits[currentLang] }
      ]}
    />

    <main>
      <!-- The opening split mirrors the About page: one anchored title, one dense proof column. -->
      <section class="am-reviews-section">
        <div class="am-reviews-split">
          <div class="am-reviews-split__left">
            <h2 class="am-display-xl">{copy.sections.summaryTitle[currentLang]}</h2>
          </div>
          <div class="am-reviews-split__right">
            <p class="am-body am-reviews-text-large">{copy.sections.summaryLead[currentLang]}</p>
            <p class="am-body">
              {copy.sections.summaryBodyOne[currentLang]}
            </p>
            <p class="am-body">
              {copy.sections.summaryBodyTwo[currentLang].before}
              <a href={resolveLink('direct_booking_benefits', currentLang)} class="am-inline-link">{copy.sections.summaryBodyTwo[currentLang].linkLabel}</a>
              {copy.sections.summaryBodyTwo[currentLang].after}
            </p>
          </div>
        </div>
      </section>

      <section class="am-reviews-section am-reviews-quote-block">
        <blockquote class="am-reviews-quote">
          &ldquo;{copy.sections.quote[currentLang]}&rdquo;
        </blockquote>
      </section>

      <section class="am-reviews-section">
        <div class="am-reviews-section-header">
          <h2 class="am-section-title">{copy.sections.reviewsTitle[currentLang]}</h2>
          <p class="am-body am-reviews-section-note">{copy.sections.reviewsNote[currentLang]}</p>
        </div>

        <div class="am-reviews-grid">
          {copy.reviews.map((review) => (
            <article class="am-reviews-card">
              <p class="am-kicker am-reviews-card__meta">{review.meta[currentLang]}</p>
              <p class="am-body am-reviews-card__copy">&ldquo;{review.copy[currentLang]}&rdquo;</p>
            </article>
          ))}
        </div>
      </section>

      <section class="am-reviews-section am-reviews-proof">
        <div class="am-reviews-proof__header">
          <h2 class="am-section-title">{copy.sections.mentionsTitle[currentLang]}</h2>
          <p class="am-body am-reviews-proof__note">{copy.sections.mentionsNote[currentLang]}</p>
        </div>

        <div class="am-reviews-list">
          {copy.proofPoints[currentLang].map((item) => (
            <div class="am-reviews-list__item">
              <p class="am-body am-reviews-list__copy">{item}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Awards are grouped clearly, but kept editorial rather than widget-like. -->
      <section class="am-reviews-section am-reviews-awards">
        <div class="am-reviews-awards__header">
          <h2 class="am-section-title am-reviews-awards__title">{copy.sections.awardsTitle[currentLang]}</h2>
          <p class="am-body">{copy.sections.awardsBody[currentLang]}</p>
          <p class="am-body am-reviews-awards__source">{copy.sections.awardsSource[currentLang]}</p>
        </div>

        <div class="am-reviews-awards__grid">
          <div class="am-reviews-awards__group">
            <h3 class="am-reviews-awards__label">Frigiliana</h3>
            <ul class="am-body am-reviews-ul">
              {copy.awards.frigiliana.map((award) => (
                <li>{award}</li>
              ))}
            </ul>
          </div>

          <div class="am-reviews-awards__group">
            <h3 class="am-reviews-awards__label">Nerja & Tarifa</h3>
            <ul class="am-body am-reviews-ul">
              {copy.awards.coast.map((award) => (
                <li>{award}</li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <section class="am-reviews-section am-reviews-locations">
        <div class="am-reviews-locations__header">
          <h2 class="am-section-title">{copy.sections.locationTitle[currentLang]}</h2>
          <p class="am-body">{copy.sections.locationLead[currentLang]}</p>
        </div>

        <div class="am-reviews-locations__trio">
          <a href={resolveLink('location_frigiliana', currentLang)} class="am-reviews-location">
            <div class="am-reviews-location__image"><span>Frigiliana</span></div>
            <div class="am-reviews-location__caption">
              <h3 class="am-reviews-location__title">Frigiliana</h3>
              <p class="am-body">{copy.sections.locationFrigiliana[currentLang]}</p>
            </div>
          </a>

          <span class="am-reviews-location am-link-disabled">
            <div class="am-reviews-location__image"><span>Nerja</span></div>
            <div class="am-reviews-location__caption">
              <h3 class="am-reviews-location__title">Nerja</h3>
              <p class="am-body">{copy.sections.locationNerja[currentLang]}</p>
            </div>
          </span>

          <span class="am-reviews-location am-link-disabled">
            <div class="am-reviews-location__image"><span>Tarifa</span></div>
            <div class="am-reviews-location__caption">
              <h3 class="am-reviews-location__title">Tarifa</h3>
              <p class="am-body">{copy.sections.locationTarifa[currentLang]}</p>
            </div>
          </span>
        </div>
      </section>

      <section class="am-reviews-section am-reviews-cta">
        <h2 class="am-reviews-cta__title">{copy.sections.nextTitle[currentLang]}</h2>
        <p class="am-body am-reviews-cta__lead">
          {copy.sections.nextLead[currentLang]}
        </p>

        <div class="am-reviews-cta__links">
          <span class="am-reviews-link am-link-disabled">{copy.sections.ctaBook[currentLang]}</span>
          <span class="am-reviews-cta__dot">&middot;</span>
          <span class="am-reviews-link am-link-disabled">{copy.sections.ctaExplore[currentLang]}</span>
          <span class="am-reviews-cta__dot">&middot;</span>
          <a href={resolveLink('direct_booking_benefits', currentLang)} class="am-reviews-link">{copy.sections.ctaBenefits[currentLang]}</a>
        </div>
      </section>
    </main>
    </div>
  </div>
</BaseLayout>

<style>
