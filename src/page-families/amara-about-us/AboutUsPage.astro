---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import TrustHero from '../../components/hero/TrustHero.astro';
import EditorialQuote from '../../components/editorial/EditorialQuote.astro';
import EditorialSplit from '../../components/editorial/EditorialSplit.astro';
import EditorialStatement from '../../components/editorial/EditorialStatement.astro';
import EditorialDefinitionList from '../../components/editorial/EditorialDefinitionList.astro';
import EditorialFeatureGrid from '../../components/editorial/EditorialFeatureGrid.astro';
import SustainabilityBand from '../../components/editorial/SustainabilityBand.astro';
import EditorialHostProfile from '../../components/editorial/EditorialHostProfile.astro';
import EditorialClosingCta from '../../components/editorial/EditorialClosingCta.astro';
import { getAboutUsPageData } from '../../content/aboutUsContent';
import { resolveLink } from '../../lib/linkResolver';
import { normalizeLanguage } from '../../lib/seo/resolve-seo-head';
import type { AmaraLanguage } from '../../types/seo';

const { lang = 'es' } = Astro.props;
const currentLang = normalizeLanguage(lang as AmaraLanguage);
const page = getAboutUsPageData(currentLang);
const content = page.content;

const principlesDefinitionItems = (content.principles.items ?? []).map((item) => ({
  title: item.title[currentLang],
  description: item.copy[currentLang]
}));

const qualityFeatureCards = content.quality.cards.map((card) => ({
  title: card.title[currentLang],
  ...(card.subline ? { subline: card.subline[currentLang] } : {}),
  copy: card.copy[currentLang]
}));

const sustainabilityListColumns =
  content.sustainability.listColumns?.map((column) => ({
    label: column.label[currentLang],
    items: column.items.map((item) => item[currentLang])
  })) ?? [];

const hostStats =
  content.host.stats?.map((stat) => ({
    label: stat.label[currentLang],
    value: stat.value[currentLang]
  })) ?? [];

const closingCtaLinks = content.closingCta.links.map((link) => ({
  token: link.token,
  label: link.label[currentLang]
}));
---

<BaseLayout seo={page.seo} pageLang={currentLang} footerHighlights={page.footerHighlights}>
  <Navigation
    currentLang={currentLang}
    brandName="AMARA"
    brandLabel={page.brandLabel}
    links={page.navigationLinks}
    variant="trust"
    languageToken="about"
    ctaLabel={page.navCtaLabel}
  />
  <div class="am-root bg-white" data-am-page="about">
    <div class="am-wrap w-full max-w-[1400px] mx-auto px-[5vw]">
    <TrustHero
      subtitle={page.hero.subtitle}
      title={page.hero.titleHtml}
      lead={page.hero.lead}
      supportText={page.hero.supportText}
      ctaLinks={page.hero.ctaLinks.map((link) => ({
        href: resolveLink(link.token, currentLang),
        label: link.label
      }))}
    />

    <main>
      <section class="mb-[clamp(8rem,15vw,14rem)]">
        <EditorialSplit title={content.philosophy.title?.[currentLang] ?? ''}>
          <p class="am-text-subtitle leading-[1.5] text-on-surface mb-8">
            {content.philosophy.lead?.[currentLang]}
          </p>
          {content.philosophy.paragraphs?.map((paragraph) => (
            <p class="am-text-body text-subtle">{paragraph[currentLang]}</p>
          ))}
          <div class="h-16 w-full shrink-0" aria-hidden="true"></div>
          <h3 class="am-text-subtitle font-semibold text-on-surface mb-4">{content.philosophy.subtitle?.[currentLang]}</h3>
          {content.philosophy.items?.map((item) => (
            <p class="am-text-body text-subtle">{item.copy[currentLang]}</p>
          ))}
        </EditorialSplit>
      </section>

      <div class="mb-[clamp(8rem,15vw,14rem)]">
        <EditorialQuote quote={content.quote[currentLang]} />
      </div>

      <section class="mb-[clamp(8rem,15vw,14rem)] max-w-[800px] mx-auto">
        <div class="mb-16 text-center">
          <h2 class="am-text-title">{content.principles.title?.[currentLang]}</h2>
          <p class="am-text-body italic text-muted">{content.principles.note?.[currentLang]}</p>
        </div>
        <EditorialDefinitionList items={principlesDefinitionItems} />
      </section>

      <section
        class="mb-[clamp(8rem,15vw,14rem)] bg-surface py-[clamp(4rem,8vw,8rem)] px-[clamp(2rem,5vw,5rem)] -mx-[5vw]"
      >
        <h2 class="am-text-title text-center mb-20">{content.quality.title?.[currentLang]}</h2>
        <div class="max-w-[1200px] mx-auto mb-16">
          <EditorialFeatureGrid cards={qualityFeatureCards} />
        </div>
        <p class="am-text-body text-center italic text-muted mb-24">{content.quality.note?.[currentLang]}</p>
        <EditorialStatement title={content.quality.statementTitle[currentLang]}>
          {content.quality.statementParagraphs.map((paragraph) => (
            <p class="am-text-body text-subtle">{paragraph[currentLang]}</p>
          ))}
          <p class="am-text-body font-semibold text-on-surface mt-8">{content.quality.statementStrong[currentLang]}</p>
        </EditorialStatement>
      </section>

      <section class="mb-[clamp(8rem,15vw,14rem)]">
        <div class="text-center max-w-[600px] mx-auto mb-20">
          <h2 class="am-text-title">{content.locations.title?.[currentLang]}</h2>
          <p class="am-text-body text-subtle">{content.locations.lead?.[currentLang]}</p>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-[clamp(2rem,4vw,4rem)]">
          {content.locations.locations?.map((location) => (
            <figure class="m-0">
              <div
                class="aspect-[3/4] bg-black/[0.03] flex items-center justify-center mb-6"
              >
                <span class="am-text-subtitle italic text-on-surface/60">{location.name}</span>
              </div>
              <figcaption>
                <h3 class="am-text-subtitle font-light text-on-surface mb-2">{location.name}</h3>
                <p class="am-text-body text-subtle">{location.copy[currentLang]}</p>
              </figcaption>
            </figure>
          ))}
        </div>
      </section>

      <EditorialHostProfile
        imageSrc="/images/robert-amara-founder-host.jpg"
        imageAlt={content.host.imageAlt[currentLang]}
        title={content.host.title?.[currentLang] ?? ''}
        role={content.host.role[currentLang]}
        stats={hostStats}
      >
        <div class="pt-12">
          <h3 class="am-text-subtitle font-semibold text-on-surface mb-4">{content.host.subtitle?.[currentLang]}</h3>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mt-8">
            {content.host.teamItems?.map((item) => (
              <div>
                <h4 class="am-text-body font-semibold text-on-surface mb-2 m-0">{item.title[currentLang]}</h4>
                <p class="am-text-body text-subtle m-0">{item.copy[currentLang]}</p>
              </div>
            ))}
          </div>
        </div>
      </EditorialHostProfile>

      <SustainabilityBand
        title={content.sustainability.title?.[currentLang] ?? ''}
        subtitle={content.sustainability.subtitle?.[currentLang] ?? ''}
        lead={content.sustainability.lead?.[currentLang] ?? ''}
        listColumns={sustainabilityListColumns}
      />

      <EditorialClosingCta
        title={content.closingCta.title?.[currentLang] ?? ''}
        lead={content.closingCta.lead?.[currentLang] ?? ''}
        note={content.closingCta.note?.[currentLang]}
        links={closingCtaLinks}
        lang={currentLang}
      />
    </main>
    </div>
  </div>
</BaseLayout>
