---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import TrustHero from '../../components/TrustHero.astro';
import { getAboutUsPageData } from '../../content/aboutUsContent';
import { resolveLink } from '../../lib/linkResolver';
import { normalizeLanguage } from '../../lib/seo/resolve-seo-head';
import type { AmaraLanguage } from '../../types/seo';

const { lang = 'es' } = Astro.props;
const currentLang = normalizeLanguage(lang as AmaraLanguage);
const page = getAboutUsPageData(currentLang);
const content = page.content;
---

<BaseLayout seo={page.seo} pageLang={currentLang} footerHighlights={page.footerHighlights}>
  <Navigation
    currentLang={currentLang}
    brandName="AMARA"
    brandLabel={page.brandLabel}
    links={page.navigationLinks}
    variant="trust"
    languageToken="about"
    ctaLabel={page.navCtaLabel}
  />
  <div class="am-exp-page">
    <TrustHero
      subtitle={page.hero.subtitle}
      title={page.hero.titleHtml}
      lead={page.hero.lead}
      supportText={page.hero.supportText}
      ctaLinks={page.hero.ctaLinks.map((link) => ({
        href: resolveLink(link.token, currentLang),
        label: link.label
      }))}
    />

    <main>
      <section class="am-exp-section am-exp-philosophy">
        <div class="am-exp-grid-split">
          <div class="am-exp-grid-split__left">
            <h2 class="am-section-title">{content.philosophy.title?.[currentLang]}</h2>
          </div>
          <div class="am-exp-grid-split__right">
            <p class="am-body am-exp-text-large">{content.philosophy.lead?.[currentLang]}</p>
            {content.philosophy.paragraphs?.map((paragraph) => (
              <p class="am-body">{paragraph[currentLang]}</p>
            ))}
            <div class="am-exp-spacer"></div>
            <h3 class="am-exp-subtitle">{content.philosophy.subtitle?.[currentLang]}</h3>
            {content.philosophy.items?.map((item) => (
              <p class="am-body">{item.copy[currentLang]}</p>
            ))}
          </div>
        </div>
      </section>

      <section class="am-exp-section am-exp-quote-block">
        <blockquote class="am-exp-quote">&ldquo;{content.quote[currentLang]}&rdquo;</blockquote>
      </section>

      <section class="am-exp-section am-exp-principles">
        <div class="am-exp-principles__header">
          <h2 class="am-section-title">{content.principles.title?.[currentLang]}</h2>
          <p class="am-body am-exp-principles__note">{content.principles.note?.[currentLang]}</p>
        </div>
        <div class="am-exp-list">
          {content.principles.items?.map((item) => (
            <div class="am-exp-list__item">
              <h3 class="am-exp-list__title">{item.title[currentLang]}</h3>
              <p class="am-body">{item.copy[currentLang]}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="am-exp-section am-exp-quality">
        <h2 class="am-section-title am-exp-quality__title">{content.quality.title?.[currentLang]}</h2>
        <div class="am-exp-quality__grid">
          {content.quality.cards.map((card) => (
            <div class="am-exp-quality__card">
              <div class="am-exp-quality__header">
                <h3 class="am-exp-quality__label">
                  <span class="am-exp-quality__label-main">{card.title[currentLang]}</span>
                  {card.subline && <span class="am-exp-muted am-exp-quality__subline">{card.subline[currentLang]}</span>}
                </h3>
              </div>
              <p class="am-body">{card.copy[currentLang]}</p>
            </div>
          ))}
        </div>
        <p class="am-body am-exp-quality__footer">{content.quality.note?.[currentLang]}</p>
        <div class="am-exp-statement">
          <h3 class="am-exp-statement__title">{content.quality.statementTitle[currentLang]}</h3>
          <div class="am-exp-statement__content">
            {content.quality.statementParagraphs.map((paragraph) => (
              <p class="am-body">{paragraph[currentLang]}</p>
            ))}
            <p class="am-body am-exp-statement__strong">{content.quality.statementStrong[currentLang]}</p>
          </div>
        </div>
      </section>

      <section class="am-exp-section am-exp-locations">
        <div class="am-exp-locations__header">
          <h2 class="am-section-title">{content.locations.title?.[currentLang]}</h2>
          <p class="am-body">{content.locations.lead?.[currentLang]}</p>
        </div>
        <div class="am-exp-locations__trio">
          {content.locations.locations?.map((location) => (
            <figure class="am-exp-location">
              <div class="am-exp-location__image"><span>{location.name}</span></div>
              <figcaption class="am-exp-location__caption">
                <h3 class="am-exp-location__title">{location.name}</h3>
                <p class="am-body">{location.copy[currentLang]}</p>
              </figcaption>
            </figure>
          ))}
        </div>
      </section>

      <section class="am-exp-section am-exp-host">
        <div class="am-exp-host__split">
          <div class="am-exp-host__visual">
            <div class="am-exp-host__portrait">
              <img src="/images/robert-amara-founder-host.jpg" alt={content.host.imageAlt[currentLang]} loading="lazy" decoding="async" />
            </div>
          </div>
          <div class="am-exp-host__content">
            <h2 class="am-section-title">{content.host.title?.[currentLang]}</h2>
            <p class="am-kicker am-exp-host__role">{content.host.role[currentLang]}</p>
            <dl class="am-exp-stats">
              {content.host.stats?.map((stat) => (
                <div class="am-exp-stats__item">
                  <dt class="am-exp-stats__label">{stat.label[currentLang]}</dt>
                  <dd class="am-body am-exp-stats__value">{stat.value[currentLang]}</dd>
                </div>
              ))}
            </dl>
            <div class="am-exp-team">
              <h3 class="am-exp-subtitle">{content.host.subtitle?.[currentLang]}</h3>
              <div class="am-exp-team__grid">
                {content.host.teamItems?.map((item) => (
                  <div>
                    <h4 class="am-exp-team__label">{item.title[currentLang]}</h4>
                    <p class="am-body">{item.copy[currentLang]}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="am-exp-section am-exp-sustainability">
        <div class="am-exp-sustainability__inner">
          <div class="am-exp-sustainability__header">
            <h2 class="am-section-title">{content.sustainability.title?.[currentLang]}</h2>
            <p class="am-kicker">{content.sustainability.subtitle?.[currentLang]}</p>
          </div>
          <div class="am-exp-sustainability__content">
            <p class="am-body am-exp-text-large">{content.sustainability.lead?.[currentLang]}</p>
            <div class="am-exp-sustainability__lists">
              {content.sustainability.listColumns?.map((column) => (
                <div class="am-exp-sustainability__list">
                  <h3 class="am-exp-sustainability__label">{column.label[currentLang]}</h3>
                  <ul class="am-body am-exp-ul">
                    {column.items.map((item) => (
                      <li>{item[currentLang]}</li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section class="am-exp-section am-exp-cta">
        <h2 class="am-exp-cta__title">{content.closingCta.title?.[currentLang]}</h2>
        <p class="am-body am-exp-cta__lead">{content.closingCta.lead?.[currentLang]}</p>
        <p class="am-body am-exp-cta__sub">{content.closingCta.note?.[currentLang]}</p>
        <div class="am-cta-group">
          {content.closingCta.links.map((link, index) => (
            <>
              {index > 0 && <span class="am-exp-cta__dot">&middot;</span>}
              <a href={resolveLink(link.token, currentLang)} class="am-cta-link">{link.label[currentLang]}</a>
            </>
          ))}
        </div>
      </section>
    </main>
  </div>
</BaseLayout>

<style>
  .am-exp-page {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 5vw;
    background-color: #ffffff;
  }
  .am-exp-section { margin-bottom: clamp(8rem, 15vw, 14rem); }
  .am-exp-text-large { font-size: clamp(1.25rem, 2vw, 1.5rem); line-height: 1.5; color: #111; margin-bottom: 2rem; }
  .am-exp-subtitle { font-family: "Plus Jakarta Sans", sans-serif; font-size: 1.25rem; font-weight: 600; color: #111; margin-bottom: 1rem; }
  .am-exp-muted { color: #888; font-weight: 400; }
  .am-exp-spacer { height: 4rem; }
  .am-exp-grid-split { display: grid; grid-template-columns: 1.2fr 1.8fr; gap: clamp(4rem, 8vw, 8rem); }
  .am-exp-grid-split__left { position: relative; }
  .am-exp-grid-split__left .am-section-title { position: sticky; top: 2rem; }
  .am-exp-grid-split__right { max-width: 65ch; }
  .am-exp-grid-split__right p { margin-bottom: 1.5rem; }
  .am-exp-quote-block { padding: clamp(4rem, 8vw, 8rem) 0; text-align: center; max-width: 1000px; margin-left: auto; margin-right: auto; }
  .am-exp-quote { font-family: "Newsreader", serif; font-size: clamp(2.5rem, 5vw, 4rem); line-height: 1.15; font-style: italic; font-weight: 300; color: #111; margin: 0; }
  .am-exp-principles { max-width: 800px; margin-left: auto; margin-right: auto; }
  .am-exp-principles__header { margin-bottom: 4rem; text-align: center; }
  .am-exp-principles__note { font-style: italic; color: #666; }
  .am-exp-list { border-top: 2px solid #111; }
  .am-exp-list__item { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; padding: 2rem 0; border-bottom: 1px solid rgba(0,0,0,0.1); }
  .am-exp-list__title { font-family: "Plus Jakarta Sans", sans-serif; font-size: 1.125rem; font-weight: 600; color: #111; margin: 0; }
  .am-exp-quality { background-color: #fcfbf9; padding: clamp(4rem, 8vw, 8rem) clamp(2rem, 5vw, 5rem); margin-left: -5vw; margin-right: -5vw; }
  .am-exp-quality__title { text-align: center; margin-bottom: 5rem; }
  .am-exp-quality__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 4rem 3rem; max-width: 1200px; margin: 0 auto 4rem; }
  .am-exp-quality__header { min-height: 3.6rem; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid rgba(0,0,0,0.1); display: flex; align-items: flex-start; }
  .am-exp-quality__label { font-family: "Plus Jakarta Sans", sans-serif; font-size: 1rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; line-height: 1.05; margin: 0; }
  .am-exp-quality__subline { display: block; margin-top: 0.08rem; line-height: 1.05; }
  .am-exp-quality__footer { text-align: center; font-style: italic; color: #666; margin-bottom: 6rem; }
  .am-exp-statement { max-width: 800px; margin: 0 auto; background: #fff; padding: clamp(3rem, 6vw, 5rem); border: 1px solid rgba(0,0,0,0.05); box-shadow: 0 20px 40px rgba(0,0,0,0.02); }
  .am-exp-statement__title { font-family: "Newsreader", serif; font-size: 2rem; font-weight: 300; margin-bottom: 2rem; color: #111; }
  .am-exp-statement__content p { margin-bottom: 1.25rem; }
  .am-exp-statement__strong { font-weight: 600; color: #111; margin-top: 2rem; }
  .am-exp-locations__header { text-align: center; max-width: 600px; margin: 0 auto 5rem; }
  .am-exp-locations__trio { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(2rem, 4vw, 4rem); }
  .am-exp-location { margin: 0; }
  .am-exp-location__image { aspect-ratio: 3/4; background-color: rgba(0,0,0,0.03); display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem; }
  .am-exp-location__image span { font-family: "Newsreader", serif; font-style: italic; color: rgba(0,0,0,0.3); }
  .am-exp-location__title { font-family: "Newsreader", serif; font-size: 1.75rem; font-weight: 300; margin-bottom: 0.5rem; }
  .am-exp-host__split { display: grid; grid-template-columns: 4fr 6fr; gap: clamp(4rem, 8vw, 8rem); align-items: start; }
  .am-exp-host__portrait { aspect-ratio: 4/5; background-color: rgba(0,0,0,0.03); display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .am-exp-host__portrait img { width: 100%; height: 100%; object-fit: cover; object-position: center; display: block; }
  .am-exp-host__role { margin-bottom: 3rem; }
  .am-exp-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem 2rem; margin-bottom: 5rem; }
  .am-exp-stats__label { font-family: "Plus Jakarta Sans", sans-serif; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: #888; margin-bottom: 0.5rem; }
  .am-exp-stats__value { margin: 0; color: #111; }
  .am-exp-team { border-top: 1px solid rgba(0,0,0,0.1); padding-top: 3rem; }
  .am-exp-team__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-top: 2rem; }
  .am-exp-team__label { font-family: "Plus Jakarta Sans", sans-serif; font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem; }
  .am-exp-sustainability { background-color: #dcefe6; color: #1d3128; padding: clamp(4rem, 8vw, 8rem) clamp(2rem, 5vw, 5rem); margin-left: -5vw; margin-right: -5vw; }
  .am-exp-sustainability__inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 2fr; gap: clamp(4rem, 8vw, 8rem); }
  .am-exp-sustainability .am-section-title, .am-exp-sustainability .am-body, .am-exp-sustainability .am-exp-text-large { color: #1d3128; }
  .am-exp-sustainability .am-kicker { color: rgba(29,49,40,0.72); }
  .am-exp-sustainability__lists { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; margin-top: 4rem; }
  .am-exp-sustainability__label { font-family: "Plus Jakarta Sans", sans-serif; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(29,49,40,0.68); margin-bottom: 1.5rem; border-bottom: 1px solid rgba(29,49,40,0.18); padding-bottom: 0.5rem; }
  .am-exp-ul { list-style: none; padding: 0; margin: 0; }
  .am-exp-ul li { margin-bottom: 0.75rem; position: relative; padding-left: 1.25rem; }
  .am-exp-ul li::before { content: "—"; position: absolute; left: 0; color: rgba(29,49,40,0.42); }
  .am-exp-cta { text-align: center; max-width: 800px; margin: 0 auto; padding-bottom: 4rem; }
  .am-exp-cta__title { font-family: "Newsreader", serif; font-size: clamp(2.5rem, 4vw, 3.5rem); line-height: 1.1; font-weight: 300; color: #111; margin-bottom: 2rem; }
  .am-exp-cta__lead { font-size: clamp(1.125rem, 2vw, 1.25rem); color: #444; margin-bottom: 1rem; }
  .am-exp-cta__sub { font-style: italic; color: #666; margin-bottom: 4rem; }
  .am-exp-cta__dot { color: #ccc; }
  @media (max-width: 900px) {
    .am-exp-grid-split, .am-exp-host__split, .am-exp-sustainability__inner { grid-template-columns: 1fr; gap: 3rem; }
    .am-exp-grid-split__left .am-section-title { position: static; }
    .am-exp-locations__trio { grid-template-columns: 1fr; }
    .am-exp-list__item { grid-template-columns: 1fr; gap: 0.5rem; }
    .am-exp-host__visual { order: -1; max-width: 400px; }
  }
  @media (max-width: 600px) {
    .am-exp-stats, .am-exp-team__grid, .am-exp-sustainability__lists { grid-template-columns: 1fr; gap: 2rem; }
    .am-cta-group { flex-direction: column; gap: 1rem; }
    .am-exp-cta__dot { display: none; }
  }
</style>
