---

<BaseLayout seo={seo} pageLang={currentLang} footerHighlights={footerHighlights}>
  <Navigation
    currentLang={currentLang}
    brandName="AMARA"
    brandLabel={navBrandLabel[currentLang]}
    links={page.trustLinks}
    variant="trust"
    languageToken="amenities"
    ctaLabel={navCtaLabel[currentLang]}
  />

  <style>
    @reference "../../styles/global.css";

    #am-page-amenities .am-exp-page {
      @apply bg-white;
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 5vw;
    }

    #am-page-amenities .am-wrap {
      width: min(100%, 76rem);
      margin: 0 auto;
      padding: 0 1.5rem 5rem;
    }

    #am-page-amenities .am-section {
      margin-bottom: 3rem;
    }

    #am-page-amenities .am-prose {
      max-width: 46rem;
    }

    #am-page-amenities .am-body,
    #am-page-amenities .am-small,
    #am-page-amenities .am-elist-title,
    #am-page-amenities .am-elist-desc,
    #am-page-amenities .am-list-specs,
    #am-page-amenities .am-inline-link,
    #am-page-amenities .am-btn {
      font-family: var(--font-body);
    }

    #am-page-amenities .am-h2 {
      margin: 0 0 1rem;
      font-family: var(--font-display, var(--font-body));
      font-size: clamp(1.5rem, 3vw, 2rem);
      font-weight: 500;
      line-height: 1.05;
      letter-spacing: -0.02em;
    }

    #am-page-amenities .am-grid {
      display: block;
    }

    #am-page-amenities .am-card {
      margin: 0 0 2.5rem;
      border: 0;
      border-radius: 0;
      background: none;
      box-shadow: none;
    }

    #am-page-amenities .am-card-body {
      padding: 0;
    }

    #am-page-amenities .am-elist {
      display: block;
    }

    #am-page-amenities .am-elist-item {
      display: block;
      margin-bottom: 1rem;
    }

    #am-page-amenities .am-elist-title {
      margin: 0 0 0.2rem;
      font-size: 0.95rem;
      font-weight: 600;
      color: rgba(0, 0, 0, 0.84);
    }

    #am-page-amenities .am-elist-desc {
      margin: 0;
      font-size: 0.95rem;
      line-height: 1.65;
      color: rgba(0, 0, 0, 0.68);
    }

    #am-page-amenities .am-list-specs {
      margin: 1rem 0 0;
      padding: 0;
      list-style: none;
      display: grid;
      gap: 0.55rem;
      font-size: 0.95rem;
      line-height: 1.6;
      color: rgba(0, 0, 0, 0.76);
    }

    #am-page-amenities .am-list-specs li {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      padding-bottom: 0.55rem;
      border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    }

    #am-page-amenities .am-list-specs strong {
      font-weight: 600;
      color: rgba(0, 0, 0, 0.88);
    }

    #am-page-amenities .am-list-specs span {
      text-align: right;
    }

    #am-page-amenities .am-inline-link {
      color: rgba(0, 0, 0, 0.72);
      text-decoration: underline;
      text-underline-offset: 0.18em;
    }

    #am-page-amenities .am-btn-row {
      margin-top: 1.25rem;
    }

    #am-page-amenities .am-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.9rem;
      padding: 0.8rem 1.2rem;
      border-radius: 0.95rem;
      text-decoration: none;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    #am-page-amenities .am-btn--primary {
      background: #111;
      color: #fff;
    }

    #am-page-amenities .am-small {
      margin: 1rem 0 0;
      font-size: 0.95rem;
      line-height: 1.7;
      color: rgba(0, 0, 0, 0.64);
    }

    /* =========================================================
       PAGE-LOCAL SAFETY ONLY (NO language logic)
       - AI status indicator
       - Icon safety fix if global CSS fails
       ========================================================= */

    /* AI Data Protection & Status Light */
    #amara-ai-status-indicator {
      display: inline-block;
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background-color: #e74c3c;
      margin-left: 10px;
      opacity: 0.8;
      cursor: help;
      transition: all 0.3s ease;
      vertical-align: middle;
    }

    #amara-ai-status-indicator.status-ok {
      background-color: #2ecc71 !important;
      box-shadow: 0 0 8px #2ecc71;
    }

    /* ICON SAFETY FIX (forces icons small & gold if global CSS fails) */
    .am-root .am-elist-ico {
      display: none !important;
    }

    .am-root .am-elist-ico svg {
      display: none !important;
    }

    @media (max-width: 720px) {
      #am-page-amenities .am-wrap {
        padding-inline: 1rem;
      }

      #am-page-amenities .am-list-specs li {
        flex-direction: column;
        gap: 0.2rem;
      }

      #am-page-amenities .am-list-specs span {
        text-align: left;
      }
    }
  </style>

  <div id="am-page-amenities" class="am-root" data-am-page="amenities" data-current-lang={currentLang}>
    <section aria-label={page.sections.inventoryAria}>
      <div class="am-exp-page">
        <TrustHero
          subtitle={page.hero.subtitle}
          title={page.hero.title}
          lead={page.hero.lead}
          supportText={page.hero.supportText}
          ctaLinks={[
            { href: resolveLink('about', currentLang), label: page.hero.ctaAbout },
            { href: resolveLink('reviews_hub', currentLang), label: page.hero.ctaReviews }
          ]}
        />
      </div>

      <div class="am-wrap">

        <section class="am-section" aria-label={page.sections.conceptAria}>
          <h2 class="am-h2">{page.sections.conceptTitle}</h2>

          <div class="am-grid">
            <article class="am-card">
              <div class="am-card-body">
                <h3 class="am-h2">{page.sections.coreTitle}</h3>

                <div class="am-elist is-tight">
                  {page.bullets.core.map((bullet, index) => (
                    <div class="am-elist-item">
                      <div class="am-elist-ico" aria-hidden="true">
                        {index === 0 && (
                          <svg viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
                        )}
                        {index === 1 && (
                          <svg viewBox="0 0 24 24"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><line x1="23" y1="9" x2="17" y2="15"></line><line x1="17" y1="9" x2="23" y2="15"></line></svg>
                        )}
                        {index === 2 && (
                          <svg viewBox="0 0 24 24"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path></svg>
                        )}
                      </div>
                      <div class="am-elist-body">
                        <p class="am-elist-title">{bullet.title}</p>
                        <p class="am-elist-desc">{bullet.desc}</p>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </article>

            <article class="am-card">
              <div class="am-card-body">
                <h3 class="am-h2">{page.sections.separateTitle}</h3>

                <div class="am-elist is-tight">
                  {page.bullets.separate.map((bullet, index) => (
                    <div class="am-elist-item">
                      <div class="am-elist-ico" aria-hidden="true">
                        {index === 0 && (
                          <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                        )}
                        {index === 1 && (
                          <svg viewBox="0 0 24 24"><path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"></path></svg>
                        )}
                        {index === 2 && (
                          <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                        )}
                      </div>
                      <div class="am-elist-body">
                        <p class="am-elist-title">{bullet.title}</p>
                        <p class="am-elist-desc">{bullet.desc}</p>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </article>
          </div>
        </section>

        <section class="am-section" aria-label={page.sections.inventoryAria}>
          <h2 class="am-h2">{page.sections.inventoryTitle}</h2>

          <div class="am-grid">
            {properties.map((property) => (
              <article class="am-card" data-rental-id={property.id}>
                <div class="am-card-body">
                  <h3 class="am-h2">{property.name}</h3>
                  <div class="am-prose">
                    <p class="am-body">
                      <a class="am-inline-link" href={property.href}>{page.inventory.detailsLabel}</a>
                    </p>
                  </div>

                  <ul class="am-list-specs">
                    <li><strong>{page.inventory.labels.license}</strong> <span>{property.specs.license}</span></li>
                    <li><strong>{page.inventory.labels.maxOccupancy}</strong> <span>{property.specs.maxOccupancy[currentLang]}</span></li>
                    {property.specs.bed && <li><strong>{page.inventory.labels.bed}</strong> <span>{property.specs.bed}</span></li>}
                    {property.specs.beds && <li><strong>{page.inventory.labels.beds}</strong> <span>{property.specs.beds[currentLang]}</span></li>}
                    <li><strong>{page.inventory.labels.price}</strong> <span>{property.specs.price[currentLang]}</span></li>
                    <li><strong>{page.inventory.labels.accessNote}</strong> <span>{property.specs.accessNote[currentLang]}</span></li>
                    <li><strong>{page.inventory.labels.pets}</strong> <span>{property.specs.pets[currentLang]}</span></li>
                    {property.specs.pool && <li><strong>{page.inventory.labels.pool}</strong> <span>{property.specs.pool[currentLang]}</span></li>}
                    <li><strong>{page.inventory.labels.view}</strong> <span>{property.specs.view[currentLang]}</span></li>
                    <li><strong>{page.inventory.labels.outdoor}</strong> <span>{property.specs.outdoor[currentLang]}</span></li>
                    <li><strong>{page.inventory.labels.kitchen}</strong> <span>{property.specs.kitchen[currentLang]}</span></li>
                  </ul>

                  <div class="am-btn-row">
                    <a href={property.href} class="am-btn am-btn--primary">{page.inventory.directBooking}</a>
                  </div>
                </div>
              </article>
            ))}
          </div>

          <div class="am-prose">
            <p class="am-small">
              <strong>{page.noteTitle}</strong> {page.noteText}
            </p>

            <p class="am-small" style="font-size: 0.75rem; color: #999; margin-top: 2rem; border-top: 1px solid #eee; padding-top: 10px;">
              {page.aiLegalLabel} <span id="amara-ai-status-indicator" title="Initializing..."></span>
            </p>
          </div>
        </section>
      </div>
    </section>

