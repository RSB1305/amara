---
// src/layouts/UtilityLayout.astro
import BaseLayout from './BaseLayout.astro';
import type { AmaraAuthoringSeo } from '../types/seo';

interface Props {
  seo: AmaraAuthoringSeo;
  title: string;
  subtitle?: string;
}

const { seo, title, subtitle } = Astro.props;
---

<BaseLayout seo={seo}>
  <div class="max-w-screen-xl mx-auto px-12 pt-40 pb-20">
    <header class="mb-20 border-b border-black/10 pb-12">
      <span class="label-md font-label text-primary mb-4 block">Utility / Guide</span>
      <h1 class="text-6xl font-headline italic text-on-surface mb-6">{title}</h1>
      {subtitle && <p class="font-body text-on-surface-variant text-xl italic opacity-70 max-w-2xl">{subtitle}</p>}
    </header>

    <main class="grid grid-cols-1 lg:grid-cols-12 gap-20">
      <div class="lg:col-span-8">
        <slot />
      </div>
      
      <aside class="lg:col-span-4 space-y-12">
        <slot name="sidebar" />
      </aside>
    </main>
  </div>

  <slot name="bottom" />
  <slot name="closing" />
</BaseLayout>
