---
// src/layouts/LocationAuthorityLayout.astro
import BaseLayout from './BaseLayout.astro';
import type { AmaraAuthoringSeo, AmaraLanguage } from '../types/seo';

interface Props {
  seo: AmaraAuthoringSeo;
  pageLang?: AmaraLanguage;
  bodyBackgroundClass?: string;
}

const { seo, pageLang, bodyBackgroundClass } = Astro.props;
---

<BaseLayout seo={seo} pageLang={pageLang} bodyBackgroundClass={bodyBackgroundClass}>
  <main>
    <slot />
  </main>
</BaseLayout>
