---
// src/layouts/BaseLayout.astro
import type { AmaraAuthoringSeo, AmaraLanguage } from '../types/seo';
import Footer from '../components/Footer.astro';
import { normalizeLanguage, resolveSeoHead } from '../lib/seo/resolve-seo-head';
import { resolveStructuredData } from '../lib/seo/resolve-structured-data';
import '../styles/global.css';

interface Props {
  seo: AmaraAuthoringSeo;
}

const { seo } = Astro.props;

/**
 * Layout owns the document shell.
 * Runtime-derived metadata is resolved centrally here,
 * so pages do not emit parallel SEO logic.
 */
const pathname = Astro.url.pathname;
const rawLang = pathname.split('/')[1] || 'en';
const currentLang: AmaraLanguage = normalizeLanguage(rawLang);

const origin = Astro.url.origin;

const head = resolveSeoHead(seo, origin, pathname, currentLang);
const ldJson = resolveStructuredData(seo, head.canonicalUrl, currentLang, origin);
---

<!DOCTYPE html>
<html lang={currentLang} class="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{head.current.title}</title>
    <meta name="description" content={head.current.description} />
    <meta name="robots" content={head.current.robots} />
    <link rel="canonical" href={head.canonicalUrl} />

    {head.hreflangs.map((item) => (
      <link rel="alternate" hreflang={item.hreflang} href={item.href} />
    ))}

    {head.ogImage && <meta property="og:image" content={head.ogImage} />}
    <meta property="og:title" content={head.current.title} />
    <meta property="og:description" content={head.current.description} />
    <meta property="og:url" content={head.canonicalUrl} />

    {ldJson && <script type="application/ld+json" set:html={ldJson} />}
    <script type="application/json" data-amara-system set:html={head.systemBlock} />

  </head>

  <body class="bg-surface text-on-surface font-body selection:bg-primary/10 antialiased">
    <div class="grain-overlay fixed inset-0 z-[0] pointer-events-none opacity-[0.03]"></div>

    <div class="relative z-[10]">
      <slot />
      <Footer />
    </div>
  </body>
</html>
