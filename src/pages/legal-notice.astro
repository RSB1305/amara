---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import type { AmaraAuthoringSeo, AmaraLanguage } from '../types/seo';

const currentLang: AmaraLanguage = 'es';

const seo: AmaraAuthoringSeo = {
  version: '2026-03-24-legal-content-v1.0-C',
  pageType: 'C',
  entityKey: 'amara-brand',
  languages: {
    es: {
      title: 'AMARA Aviso legal y politica de privacidad',
      description: 'Aviso legal, licencias de alojamiento y politica de privacidad para amara-lodging.es. Incluye informacion de cumplimiento para Andalucia y GDPR.',
      robots: 'index, follow',
      canonical: 'auto'
    }
  }
};

const linkClass = 'underline decoration-outline-variant underline-offset-4 hover:text-primary transition-colors';
const specsClass = 'space-y-4 text-on-surface-variant text-lg leading-relaxed';
const specsItemClass = 'grid gap-2 md:grid-cols-[minmax(0,18rem)_1fr]';
const cardClass = 'bg-surface-container-lowest border border-outline-variant/10 px-8 py-8 md:px-10 md:py-10';
---

<BaseLayout seo={seo} pageLang={currentLang}>
  <Navigation
    currentLang={currentLang}
    brandName="AMARA"
    links={[]}
    variant="trust"
    languageToken="legal_notice"
  />

  <div class="bg-white">
    <div class="max-w-screen-lg mx-auto px-12 pt-40 pb-28">
      <main lang="es" aria-label="Aviso legal y privacidad" class="legal-notice-formal-headings space-y-16">
        <header class="border-b border-outline-variant/10 pb-16 space-y-6">
          <span class="label-md text-primary block">Legal</span>
          <h1 class="font-headline text-[clamp(3.25rem,8vw,5.75rem)] leading-[0.94] tracking-tight text-on-surface font-light">
            Aviso legal &amp; Politica de privacidad
          </h1>
          <p class="text-on-surface-variant text-xl leading-relaxed max-w-2xl">Aplica a amara-lodging.es y a sus subpaginas relacionadas.</p>
        </header>

        <section class="space-y-6" aria-label="Responsible for this website">
          <h2 class="font-headline text-5xl md:text-6xl tracking-tight text-on-surface">Responsible for this website</h2>
          <div class={cardClass}>
            <ul class={specsClass} aria-label="Contact details">
              <li class={specsItemClass}><strong class="text-on-surface">Name</strong> <span>Robert Sebastian Böhmer</span></li>
              <li class={specsItemClass}><strong class="text-on-surface">Address</strong> <span>C./ Chorruelo 5, 29788 Frigiliana, Spain</span></li>
              <li class={specsItemClass}><strong class="text-on-surface">Spanish Tax ID (NIE)</strong> <span>Y 77 66 788 R</span></li>
              <li class={specsItemClass}><strong class="text-on-surface">Status</strong> <span>Private landlord – No entry in the commercial register</span></li>
              <li class={specsItemClass}><strong class="text-on-surface">Country</strong> <span>Spain</span></li>
              <li class={specsItemClass}><strong class="text-on-surface">Email</strong> <span><a class={linkClass} href="mailto:hola@amara-lodging.es">hola@amara-lodging.es</a></span></li>
              <li class={specsItemClass}><strong class="text-on-surface">Phone</strong> <span><a class={linkClass} href="tel:+34604440964">+34 604 440 964</a></span></li>
            </ul>
          </div>
        </section>

        <section class="space-y-6" aria-label="Rental licenses and registrations">
          <h2 class="font-headline text-5xl md:text-6xl tracking-tight text-on-surface">Rental licenses &amp; registrations</h2>
          <div class="space-y-6">
            <div class={cardClass}>
              <h3 class="font-headline text-3xl text-on-surface mb-6">Nerja</h3>
              <ul class={specsClass}>
                <li class={specsItemClass}><strong class="text-on-surface">Regional license</strong> <span>VFT/MA/19212</span></li>
                <li class={specsItemClass}><strong class="text-on-surface">Registration (NRUA)</strong> <span><code class="break-all font-mono text-sm text-on-surface">ESFCTU0000290130000818750000000000000000VUT/MA/192120</code></span></li>
              </ul>
            </div>
            <div class={cardClass}>
              <h3 class="font-headline text-3xl text-on-surface mb-6">Frigiliana</h3>
              <ul class={specsClass}>
                <li class={specsItemClass}><strong class="text-on-surface">Regional license</strong> <span>A/MA/01767</span></li>
                <li class={specsItemClass}><strong class="text-on-surface">Registration (NRUA)</strong> <span>Not required (License Class 'A')</span></li>
              </ul>
            </div>
            <div class={cardClass}>
              <h3 class="font-headline text-3xl text-on-surface mb-6">Tarifa</h3>
              <ul class={specsClass}>
                <li class={specsItemClass}><strong class="text-on-surface">Regional license</strong> <span>VFT/CA/17038</span></li>
                <li class={specsItemClass}><strong class="text-on-surface">Registration (NRUA)</strong> <span><code class="break-all font-mono text-sm text-on-surface">ESFCTU0000110140004256770000000000000000VFT/CA/170387</code></span></li>
              </ul>
            </div>
          </div>
          <p class="text-on-surface-variant italic text-lg leading-relaxed">
            Private holiday rental activity. No registered company, no trade register entry.
          </p>
        </section>

        <section class="space-y-6" aria-label="Consumer protection">
          <h2 class="font-headline text-5xl md:text-6xl tracking-tight text-on-surface">Consumer protection &amp; Dispute resolution</h2>
          <div class={cardClass}>
            <div class="space-y-6">
              <p class="text-on-surface-variant text-lg leading-relaxed">
                <strong class="text-on-surface">Official Complaint Forms (Andalusia):</strong><br />
                Official complaint forms (Hojas de Quejas y Reclamaciones) of the Junta de Andalucía are available to consumers upon request.
              </p>
              <p class="text-on-surface-variant text-lg leading-relaxed">
                <strong class="text-on-surface">Dispute Resolution:</strong><br />
                We are neither obliged nor willing to participate in dispute settlement proceedings before a consumer arbitration board.
              </p>
            </div>
          </div>
        </section>

        <section class="space-y-6" aria-label="Privacy policy">
          <h2 class="font-headline text-5xl md:text-6xl tracking-tight text-on-surface">Privacy Policy</h2>
          <p class="text-on-surface-variant text-lg leading-relaxed">Last updated: <strong class="text-on-surface">2026-02-17</strong></p>
          <div class={cardClass}>
            <div class="space-y-8">
              <div class="space-y-4">
                <h3 class="font-headline text-3xl text-on-surface">1. General Information</h3>
                <p class="text-on-surface-variant text-lg leading-relaxed">
                  We take the protection of your personal data seriously. We process personal data (e.g., name, contact details, payment information) primarily to fulfill the rental contract (Art. 6(1)(b) GDPR) and comply with legal obligations (Art. 6(1)(c) GDPR).
                </p>
              </div>
              <div class="space-y-4">
                <h3 class="font-headline text-3xl text-on-surface">2. Hosting &amp; Software (Lodgify)</h3>
                <p class="text-on-surface-variant text-lg leading-relaxed">
                  The website and booking functionality are provided via <strong class="text-on-surface">Lodgify (Codebay Solutions Ltd.)</strong>. When you book or send an inquiry, personal data is processed to facilitate the reservation. Lodgify acts as a <strong class="text-on-surface">data processor</strong> on our behalf (Art. 28 GDPR) in accordance with GDPR requirements.
                </p>
              </div>
              <div class="space-y-4">
                <h3 class="font-headline text-3xl text-on-surface">3. Payments (Stripe &amp; PayPal)</h3>
                <p class="text-on-surface-variant text-lg leading-relaxed">
                  For payments, we integrate services from <strong class="text-on-surface">Stripe</strong> and <strong class="text-on-surface">PayPal</strong>. Unlike our hosting provider, these financial institutions act as <strong class="text-on-surface">independent data controllers</strong> for the processing of transactions and fraud prevention.
                </p>
                <p class="text-on-surface-variant text-lg leading-relaxed">
                  <strong class="text-on-surface">International Transfers:</strong> The use of these services involves the transfer of data to third countries (e.g., USA). This is secured by Standard Contractual Clauses (SCCs) and/or the EU-US Data Privacy Framework to ensure an adequate level of data protection.
                </p>
              </div>
              <div class="space-y-4">
                <h3 class="font-headline text-3xl text-on-surface">4. Contact Form</h3>
                <p class="text-on-surface-variant text-lg leading-relaxed">
                  When you contact us via the website contact form, we process the information you submit (e.g., name, email address, phone number, message) to respond to your request. Legal basis is Art. 6(1)(b) GDPR (pre-contractual steps) and/or Art. 6(1)(f) GDPR (legitimate interest).
                </p>
                <p class="text-on-surface-variant text-lg leading-relaxed">
                  The submission is technically transmitted via our provider and forwarded to our inbox. We delete this data once the request is resolved, subject to retention periods. We employ SSL/TLS encryption to protect your data.
                </p>
              </div>
              <div class="space-y-4">
                <h3 class="font-headline text-3xl text-on-surface">5. Legal Reporting &amp; Guest Registration (Chekin)</h3>
                <p class="text-on-surface-variant text-lg leading-relaxed">
                  <strong class="text-on-surface">Obligation:</strong> Under Spanish law (Real Decreto 933/2021), we are legally obliged to transmit guest data (including passport/ID details) to the Ministry of Interior's central register (Ses.Hospedajes) within 24 hours of arrival.
                </p>
                <p class="text-on-surface-variant text-lg leading-relaxed">
                  <strong class="text-on-surface">Tool used:</strong> To fulfill this obligation and automate the check-in process, we use the service <strong class="text-on-surface">Chekin (Chekin Soluciones Digitales S.L.)</strong>. Chekin acts as a <strong class="text-on-surface">data processor</strong> on our behalf (Art. 28 GDPR), securely scanning ID documents and transmitting the required data to the authorities.
                </p>
              </div>
              <div class="space-y-4">
                <h3 class="font-headline text-3xl text-on-surface">6. Cookies &amp; Consent</h3>
                <p class="text-on-surface-variant text-lg leading-relaxed">
                  We use a secure cookie/consent solution. <strong class="text-on-surface">Analytics and marketing technologies are only activated after you have given your explicit consent (Consent Mode).</strong> You can adjust your preferences at any time via the cookie settings on this site.
                </p>
              </div>
              <div class="space-y-4">
                <h3 class="font-headline text-3xl text-on-surface">7. Data Subject Rights</h3>
                <p class="text-on-surface-variant text-lg leading-relaxed">
                  You have the right to access, rectification, erasure ("right to be forgotten"), restriction of processing, data portability, and the right to object to processing. Please contact us directly to exercise these rights.
                </p>
                <ul class={specsClass} aria-label="Privacy contact">
                  <li class={specsItemClass}><strong class="text-on-surface">Privacy contact</strong> <span><a class={linkClass} href="mailto:hola@amara-lodging.es">hola@amara-lodging.es</a></span></li>
                </ul>
              </div>
            </div>
          </div>
        </section>
      </main>
    </div>
  </div>

</BaseLayout>

<style>
  .legal-notice-formal-headings :is(h1, h2, h3) {
    font-style: normal;
  }
</style>
