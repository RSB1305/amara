---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import { resolveLink } from '../lib/linkResolver';
import type { AmaraAuthoringSeo, AmaraLanguage } from '../types/seo';

const currentLang: AmaraLanguage = 'es';

const seo: AmaraAuthoringSeo = {
  version: '2026-03-25-home-entry-v1.0-C',
  pageType: 'C',
  entityKey: 'amara-brand',
  languages: {
    en: {
      title: 'AMARA | Holiday Apartments in Andalusia',
      description: 'Discover AMARA holiday apartments in Frigiliana, Nerja, and Tarifa. Calm stays, direct booking, and verified guest trust.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    de: {
      title: 'AMARA | Ferienwohnungen in Andalusien',
      description: 'Entdecken Sie AMARA Ferienwohnungen in Frigiliana, Nerja und Tarifa. Ruhige Aufenthalte, Direktbuchung und verifizierte Gastbewertungen.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    es: {
      title: 'AMARA | Apartamentos vacacionales en Andalucía',
      description: 'Descubre los apartamentos vacacionales AMARA en Frigiliana, Nerja y Tarifa. Estancias calmadas, reserva directa y confianza verificada.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    nl: {
      title: 'AMARA | Vakantieappartementen in Andalusië',
      description: 'Ontdek AMARA vakantieappartementen in Frigiliana, Nerja en Tarifa. Rustige verblijven, direct boeken en geverifieerd vertrouwen.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    sv: {
      title: 'AMARA | Semesterlägenheter i Andalusien',
      description: 'Upptäck AMARA semesterlägenheter i Frigiliana, Nerja och Tarifa. Lugna vistelser, direktbokning och verifierad trygghet.',
      robots: 'index, follow',
      canonical: 'auto'
    }
  },
  ogImage: '/images/hero-frigiliana.jpg'
};

const trustLinks = [
  { token: 'about', label: 'Sobre AMARA' },
  { token: 'reviews_hub', label: 'Opiniones' },
  { token: 'locations_hub', label: 'Destinos' }
];

const footerHighlights = [
  { token: 'locations_hub', label: 'Explorar destinos' },
  { token: 'reviews_hub', label: 'Opiniones verificadas' },
  { token: 'book', label: 'Reservar ahora' }
];

const places = [
  {
    token: 'location_frigiliana',
    name: 'Frigiliana',
    text: 'Pueblo blanco, terrazas tranquilas y una estancia pensada para bajar el ritmo.'
  },
  {
    token: 'location_nerja',
    name: 'Nerja',
    text: 'Mar cerca, luz abierta y apartamentos cómodos para días fáciles.'
  },
  {
    token: 'location_tarifa',
    name: 'Tarifa',
    text: 'Horizonte, viento y una base serena para moverse entre playa y pueblo.'
  }
];

const reasons = [
  'Reserva directa con comunicación clara y rápida.',
  'Apartamentos preparados con atención real al descanso y la limpieza.',
  'Ubicaciones elegidas por ambiente, no por volumen.',
  'Una experiencia calmada, sin procesos innecesarios.'
];
---

<BaseLayout seo={seo} pageLang={currentLang} footerHighlights={footerHighlights}>
  <Navigation
    currentLang={currentLang}
    brandName="AMARA"
    links={trustLinks}
    variant="trust"
    brandVariant="lodging"
  />

  <div class="mx-auto w-full max-w-[1400px] bg-white px-[5vw]">
    <main class="flex w-full flex-col gap-24 pb-20 pt-20 md:pt-28">
    <section class="grid gap-10 border-b border-outline-variant/10 pb-16 md:grid-cols-[minmax(0,1.4fr)_minmax(18rem,0.9fr)] md:items-end">
      <div class="space-y-6">
        <span class="label-md text-primary block">AMARA</span>
        <h1 class="font-headline text-[clamp(3.2rem,8vw,5.8rem)] font-light leading-[0.94] tracking-tight text-on-surface">
          Apartamentos vacacionales en Andalucía
        </h1>
        <p class="max-w-2xl text-lg leading-relaxed text-on-surface-variant md:text-xl">
          Estancias serenas en Frigiliana, Nerja y Tarifa. Reserva directa, espacios cuidados y una llegada sencilla desde el primer momento.
        </p>
      </div>

      <div class="space-y-4 md:justify-self-end">
        <a
          href={resolveLink('book', currentLang)}
          class="inline-flex w-full items-center justify-center bg-primary px-6 py-4 text-sm font-semibold uppercase tracking-[0.14em] text-on-primary transition-colors hover:bg-primary-container md:w-auto md:min-w-64"
        >
          Reservar ahora
        </a>
        <a
          href={resolveLink('locations_hub', currentLang)}
          class="inline-flex w-full items-center justify-center border border-outline-variant/20 px-6 py-4 text-sm font-semibold uppercase tracking-[0.14em] text-on-surface transition-colors hover:bg-surface-container-low md:w-auto md:min-w-64"
        >
          Ver destinos
        </a>
      </div>
    </section>

    <section class="space-y-8">
      <div class="max-w-2xl space-y-3">
        <span class="label-md text-primary block">Destinos</span>
        <h2 class="font-headline text-4xl font-light tracking-tight text-on-surface md:text-5xl">Tres maneras de estar bien</h2>
        <p class="text-lg leading-relaxed text-on-surface-variant">
          Cada lugar tiene su propio ritmo. Elige el entorno que mejor encaja con tu viaje.
        </p>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        {places.map((place) => (
          <a
            href={resolveLink(place.token, currentLang)}
            class="group flex h-full flex-col justify-between gap-6 border border-outline-variant/10 bg-surface-container-lowest p-6 transition-colors hover:bg-surface-container-low"
          >
            <div class="space-y-3">
              <h3 class="font-headline text-3xl font-light text-on-surface">{place.name}</h3>
              <p class="text-base leading-relaxed text-on-surface-variant">{place.text}</p>
            </div>
            <span class="text-sm font-semibold uppercase tracking-[0.14em] text-primary">Ver apartamentos</span>
          </a>
        ))}
      </div>
    </section>

    <section class="grid gap-10 border-t border-outline-variant/10 pt-16 md:grid-cols-[minmax(0,0.9fr)_minmax(0,1.4fr)]">
      <div class="space-y-3">
        <span class="label-md text-primary block">Por qué AMARA</span>
        <h2 class="font-headline text-4xl font-light tracking-tight text-on-surface md:text-5xl">Una forma simple de alojarse</h2>
      </div>

      <ul class="space-y-4 text-lg leading-relaxed text-on-surface-variant">
        {reasons.map((reason) => (
          <li class="border-b border-outline-variant/10 pb-4 last:border-b-0 last:pb-0">{reason}</li>
        ))}
      </ul>
    </section>

    <section class="border border-outline-variant/10 bg-surface-container-low px-6 py-8 md:px-10 md:py-10">
      <div class="grid gap-8 md:grid-cols-[minmax(0,1fr)_auto] md:items-end">
        <div class="space-y-4">
          <span class="label-md text-primary block">Prueba social</span>
          <h2 class="font-headline text-4xl font-light tracking-tight text-on-surface md:text-5xl">Más de 500 opiniones verificadas</h2>
          <p class="max-w-2xl text-lg leading-relaxed text-on-surface-variant">
            Los huéspedes repiten las mismas ideas: limpieza impecable, noches tranquilas y una atención directa que facilita toda la estancia.
          </p>
        </div>

        <div>
          <a
            href={resolveLink('reviews_hub', currentLang)}
            class="inline-flex items-center justify-center border border-outline-variant/20 px-6 py-4 text-sm font-semibold uppercase tracking-[0.14em] text-on-surface transition-colors hover:bg-surface-container-high"
          >
            Leer opiniones
          </a>
        </div>
      </div>
    </section>

    <section class="space-y-6 border-t border-outline-variant/10 pt-16 text-center">
      <h2 class="font-headline text-4xl font-light tracking-tight text-on-surface md:text-5xl">Cuando quieras, el siguiente paso es fácil</h2>
      <p class="mx-auto max-w-2xl text-lg leading-relaxed text-on-surface-variant">
        Consulta disponibilidad, compara destinos y reserva directamente con AMARA.
      </p>
      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={resolveLink('book', currentLang)}
          class="inline-flex min-w-56 items-center justify-center bg-primary px-6 py-4 text-sm font-semibold uppercase tracking-[0.14em] text-on-primary transition-colors hover:bg-primary-container"
        >
          Comprobar disponibilidad
        </a>
        <a
          href={resolveLink('about', currentLang)}
          class="inline-flex min-w-56 items-center justify-center border border-outline-variant/20 px-6 py-4 text-sm font-semibold uppercase tracking-[0.14em] text-on-surface transition-colors hover:bg-surface-container-low"
        >
          Conocer AMARA
        </a>
      </div>
    </section>
    </main>
  </div>
</BaseLayout>
