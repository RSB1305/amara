---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import TrustHero from '../components/hero/TrustHero.astro';
import { resolveLink } from '../lib/linkResolver';
import type { AmaraAuthoringSeo, AmaraLanguage } from '../types/seo';

const currentLang: AmaraLanguage = 'es';

const seo: AmaraAuthoringSeo = {
  version: '2026-03-23-direct-booking-benefits-v1.0-C',
  pageType: 'C',
  entityKey: 'amara-brand',
  languages: {
    en: {
      title: 'AMARA | Direct Booking Benefits',
      description: 'Best price guarantee, direct host support, and guest-first benefits when booking directly with AMARA.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    de: {
      title: 'AMARA | Vorteile der Direktbuchung',
      description: 'Bestpreis-Garantie, direkter Gastgeberkontakt und gästefokussierte Vorteile bei einer Direktbuchung mit AMARA.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    es: {
      title: 'AMARA | Ventajas de reservar directamente',
      description: 'Mejor precio garantizado, contacto directo con el anfitrión y ventajas pensadas para el huésped al reservar con AMARA.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    nl: {
      title: 'AMARA | Voordelen van direct boeken',
      description: 'Besteprijsgarantie, direct contact met de host en gastgerichte voordelen bij rechtstreeks boeken bij AMARA.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    sv: {
      title: 'AMARA | Fördelar med direktbokning',
      description: 'Bästa pris-garanti, direkt kontakt med värden och gästfördelar när du bokar direkt med AMARA.',
      robots: 'index, follow',
      canonical: 'auto'
    }
  },
  ogImage: '/images/hero-frigiliana.jpg'
};

const benefits = [
  {
    title: 'Mejor precio garantizado',
    copy: 'Al reservar directamente, siempre obtenéis nuestro mejor precio disponible, sin costes ocultos.'
  },
  {
    title: 'Prioridad para early check-in / late check-out',
    copy: 'Cuando la disponibilidad lo permite, priorizamos early check-in o late check-out sin coste adicional.'
  },
  {
    title: 'Detalle de bienvenida',
    copy: 'Un pequeño detalle local al llegar: sencillo, cuidado y en temporada.'
  },
  {
    title: 'Contacto directo con el anfitrión',
    copy: 'Una vía más directa y sencilla para dudas y coordinación antes y durante la estancia.'
  },
  {
    title: 'Orientación flexible para la llegada',
    copy: 'Indicaciones claras de check-in, consejos de aparcamiento y ayuda para elegir el apartamento ideal.'
  },
  {
    title: 'Condiciones claras y transparentes',
    copy: 'Sin sorpresas.'
  }
];

const trustLinks = [
  { token: 'about', label: 'Sobre AMARA' },
  { token: 'reviews_hub', label: 'Opiniones de huéspedes' },
  { token: 'direct_booking_benefits', label: 'Ventajas de reserva directa' }
];

const trustFooterLabels = {
  amenities: { en: 'Amenities', de: 'Ausstattung', es: 'Servicios', nl: 'Voorzieningen', sv: 'Bekvämligheter' },
  faq_general: { en: 'Stay FAQ', de: 'Aufenthalts-FAQ', es: 'FAQ de la estancia', nl: 'Verblijfs-FAQ', sv: 'FAQ för vistelsen' },
  instagram: { en: 'Instagram', de: 'Instagram', es: 'Instagram', nl: 'Instagram', sv: 'Instagram' }
} as const;

const footerHighlights = [
  { token: 'amenities', label: trustFooterLabels.amenities[currentLang] },
  { token: 'faq_general', label: trustFooterLabels.faq_general[currentLang] },
  { token: 'instagram', label: trustFooterLabels.instagram[currentLang] }
];
---

<BaseLayout seo={seo} pageLang={currentLang} footerHighlights={footerHighlights}>
  <Navigation
    currentLang={currentLang}
    brandName="AMARA"
    links={trustLinks}
    variant="trust"
    languageToken="direct_booking_benefits"
  />
  <div class="am-exp-page">
    <TrustHero
      subtitle="Ventajas de reserva directa"
      title="Reservad directamente con AMARA y disfrutad de ventajas exclusivas"
      lead="Cuando reserváis directamente con AMARA, disfrutáis de la misma estancia preciosa con extras que facilitan la llegada y hacen la experiencia más personal."
      supportText="Transparente, sereno y centrado en el huésped, sin artificios."
      ctaLinks={[
        { href: resolveLink('about', currentLang), label: 'Sobre nosotros' },
        { href: resolveLink('reviews_hub', currentLang), label: 'Opiniones de huéspedes' }
      ]}
    />

    <main>
      <section class="am-direct-section">
        <div class="am-direct-split">
          <div class="am-direct-split__left">
            <h2 class="am-section-title">Qué obtenéis al reservar directamente</h2>
          </div>
          <div class="am-direct-split__right">
            <div class="am-direct-list">
              {benefits.map((benefit) => (
                <div class="am-direct-list__item">
                  <h3 class="am-direct-list__title">{benefit.title}</h3>
                  <p class="am-body">{benefit.copy}</p>
                </div>
              ))}
            </div>
            <p class="am-body am-direct-note">
              Consejo: si no tenéis claro qué apartamento encaja mejor, escribidnos primero y os orientaremos con calma y honestidad.
            </p>
            <div class="am-direct-inline-links">
              <a href={resolveLink('reviews_hub', currentLang)} class="am-direct-link">Opiniones de huéspedes</a>
              <span class="am-direct-inline-links__dot">&middot;</span>
              <a href={resolveLink('about', currentLang)} class="am-direct-link">Sobre AMARA</a>
            </div>
          </div>
        </div>
      </section>

      <section class="am-direct-section am-direct-quote-block">
        <blockquote class="am-direct-quote">
          &ldquo;Las reservas directas nos permiten invertir más en los detalles que realmente se notan.&rdquo;
        </blockquote>
      </section>

      <section class="am-direct-section">
        <div class="am-direct-split">
          <div class="am-direct-split__left">
            <h2 class="am-section-title">Por qué preferimos la reserva directa</h2>
          </div>
          <div class="am-direct-split__right">
            <p class="am-body am-direct-text-large">
              Las reservas directas nos permiten invertir más en los detalles que de verdad marcan la diferencia: operaciones más tranquilas, mejor mantenimiento y apoyo personal.
            </p>
            <p class="am-body">
              Además, así AMARA mantiene su independencia y sigue diseñada para huéspedes que valoran la calma.
            </p>
          </div>
        </div>
      </section>

      <section class="am-direct-section am-direct-promise-wrap">
        <div class="am-direct-promise">
          <h2 class="am-direct-promise__title">Una promesa sencilla</h2>
          <div class="am-direct-promise__content">
            <p class="am-body">
              Si encontráis las mismas fechas y condiciones por un precio más bajo en otro sitio, decídnoslo. Lo revisaremos con vosotros y haremos lo posible por igualarlo de forma justa.
            </p>
            <p class="am-body">
              Como no ofrecemos descuentos artificiales en otras plataformas, el precio directo es simplemente la base justa y más baja.
            </p>
            <p class="am-body am-direct-promise__note">Mismas fechas &middot; mismo apartamento &middot; mismas condiciones de cancelación.</p>
          </div>
        </div>
      </section>

      <section class="am-reviews-section am-reviews-cta">
        <h2 class="am-reviews-cta__title">Siguiente paso</h2>

        <p class="am-body am-reviews-cta__lead">
          Siguiente: explorad los apartamentos y usad el botón de disponibilidad cuando estéis listos.
        </p>

        <div class="am-reviews-cta__links">
          <a href={resolveLink('book', currentLang)} class="am-reviews-link">Consultar disponibilidad</a>
          <span class="am-reviews-cta__dot">&middot;</span>
          <a href={resolveLink('locations_hub', currentLang)} class="am-reviews-link">Explorar ubicaciones</a>
          <span class="am-reviews-cta__dot">&middot;</span>
          <a href={resolveLink('direct_booking_benefits', currentLang)} class="am-reviews-link">Ventajas de reserva directa</a>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>

<style>
  .am-section-title {
    font-family: "Newsreader", serif;
    font-size: clamp(2.5rem, 4.5vw, 4rem);
    line-height: 1.08;
    font-weight: 300;
    color: #111;
    margin: 0;
  }

  .am-body {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 1rem;
    line-height: 1.8;
    color: #444;
  }

  .am-exp-page {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 5vw;
  background-color: #ffffff;
}

  .am-direct-section,
  .am-reviews-section {
    margin-bottom: clamp(8rem, 15vw, 14rem);
  }

  .am-direct-text-large {
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    line-height: 1.5;
    color: #111;
    margin-bottom: 2rem;
  }

  .am-direct-link,
  .am-reviews-link {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #111;
    text-decoration: none;
    border-bottom: 1px solid rgba(0, 0, 0, 0.2);
    padding-bottom: 4px;
    transition: border-color 0.3s ease;
  }

  .am-direct-link:hover,
  .am-reviews-link:hover {
    border-color: #111;
  }

  .am-direct-inline-links,
  .am-reviews-cta__links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .am-reviews-cta__links {
    justify-content: center;
  }

  .am-direct-inline-links__dot,
  .am-reviews-cta__dot {
    color: #ccc;
  }

  .am-direct-split {
    display: grid;
    grid-template-columns: 1.2fr 1.8fr;
    gap: clamp(4rem, 8vw, 8rem);
  }

  .am-direct-split__left .am-section-title {
    position: sticky;
    top: 2rem;
  }

  .am-direct-split__right {
    max-width: 68ch;
  }

  .am-direct-quote-block {
    padding: clamp(4rem, 8vw, 8rem) 0;
    text-align: center;
    max-width: 1000px;
    margin-left: auto;
    margin-right: auto;
  }

  .am-direct-quote {
    font-family: "Newsreader", serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.15;
    font-style: italic;
    font-weight: 300;
    color: #111;
    margin: 0;
  }

  .am-direct-list {
    border-top: 2px solid #111;
    margin-bottom: 2.5rem;
  }

  .am-direct-list__item {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    padding: 2rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }

  .am-direct-list__title {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: #111;
    margin: 0;
  }

  .am-direct-note {
    color: #666;
    font-style: italic;
    margin-bottom: 2rem;
  }

  .am-direct-promise-wrap {
    background-color: #fcfbf9;
    padding: clamp(4rem, 8vw, 8rem) clamp(2rem, 5vw, 5rem);
    margin-left: -5vw;
    margin-right: -5vw;
  }

  .am-direct-promise {
    max-width: 820px;
    margin: 0 auto;
    background: #fff;
    padding: clamp(3rem, 6vw, 5rem);
    border: 1px solid rgba(0, 0, 0, 0.05);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.02);
  }

  .am-direct-promise__title {
    font-family: "Newsreader", serif;
    font-size: 2rem;
    font-weight: 300;
    margin: 0 0 2rem 0;
    color: #111;
  }

  .am-direct-promise__content p {
    margin-bottom: 1.25rem;
  }

  .am-direct-promise__note {
    color: #666;
    font-style: italic;
    margin-top: 2rem;
  }

  .am-reviews-cta {
    text-align: center;
    max-width: 850px;
    margin: 0 auto;
    padding-bottom: 4rem;
  }

  .am-reviews-cta__title {
    font-family: "Newsreader", serif;
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    line-height: 1.1;
    font-weight: 300;
    color: #111;
    margin-bottom: 1.5rem;
  }

  .am-reviews-cta__lead {
    font-size: clamp(1.125rem, 2vw, 1.25rem);
    color: #444;
    margin-bottom: 3rem;
  }

  @media (max-width: 1000px) {
    .am-direct-split,
    .am-direct-list__item {
      grid-template-columns: 1fr;
    }

    .am-direct-split__left .am-section-title {
      position: static;
    }
  }

  @media (max-width: 600px) {
    .am-direct-inline-links,
    .am-reviews-cta__links {
      flex-direction: column;
      align-items: center;
      gap: 1rem;
    }

    .am-direct-inline-links__dot,
    .am-reviews-cta__dot {
      display: none;
    }
  }
</style>





