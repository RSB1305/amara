---
import LocationAuthorityLayout from '../layouts/LocationAuthorityLayout.astro';
import Navigation from '../components/Navigation.astro';
import { normalizeLanguage } from '../lib/seo/resolve-seo-head';
import type { AmaraAuthoringSeo, AmaraLanguage } from '../types/seo';

const lang = 'en';
const currentLang = normalizeLanguage(lang as AmaraLanguage);

const seo: AmaraAuthoringSeo = {
  version: 'test-parking-v1',
  pageType: 'A',
  entityKey: 'amara-brand',
  languages: {
    en: { title: 'Test – Parking', description: 'Test', robots: 'noindex', canonical: 'auto' },
    de: { title: 'Test – Parken', description: 'Test', robots: 'noindex', canonical: 'auto' },
    es: { title: 'Test – Aparcamiento', description: 'Test', robots: 'noindex', canonical: 'auto' },
    nl: { title: 'Test – Parkeren', description: 'Test', robots: 'noindex', canonical: 'auto' },
    sv: { title: 'Test – Parkering', description: 'Test', robots: 'noindex', canonical: 'auto' },
  }
};
---

<LocationAuthorityLayout seo={seo} pageLang={currentLang} bodyBackgroundClass="bg-surface">
  <Navigation
    currentLang={currentLang}
    brandName="Frigiliana"
    links={[
      { token: 'location_frigiliana', label: 'Frigiliana' },
      { token: 'location_nerja', label: 'Nerja' },
      { token: 'explore_hub', label: 'Experiences' },
    ]}
    languageToken="test"
    locationAuthorityNav={true}
  />

  <div class="am-root" data-am-page="test-parking">
    <div class="am-wrap">

      <!-- HERO -->
      <section class="pt-32 pb-16 px-6 md:px-12 lg:px-24 max-w-[1600px] mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-end mb-16">
          <div class="lg:col-span-8">
            <span class="text-[11px] font-semibold tracking-[0.15em] uppercase text-muted mb-6 block">
              Location Authority · Frigiliana
            </span>
            <h1 class="font-serif text-5xl md:text-7xl lg:text-[6rem] leading-[0.95] tracking-tight">
              The Reality of Arrival
            </h1>
          </div>
          <div class="lg:col-span-4 pb-2">
            <p class="text-on-surface-variant font-light text-lg leading-relaxed">
              Frigiliana is not a flat coastal resort. It is vertical, stepped, and historic.
              Here, the parking question is really a question about your daily movement rhythm.
            </p>
          </div>
        </div>
        <div class="h-px w-full bg-black opacity-10"></div>
      </section>

      <!-- DECISION BLOCK -->
      <section class="py-12 px-6 md:px-12 lg:px-24 max-w-[1600px] mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
          <div class="md:col-span-4">
            <h2 class="font-serif text-3xl md:text-4xl leading-tight">Is it difficult with a car?</h2>
          </div>
          <div class="md:col-span-8 grid grid-cols-1 sm:grid-cols-2 gap-8">
            <div>
              <div class="text-[11px] font-semibold tracking-[0.15em] uppercase mb-4 border-b border-black/10 pb-2">The Short Answer</div>
              <p class="text-on-surface-variant font-light leading-relaxed">It is not inherently difficult, but it is <em>different</em>. Frigiliana rewards those who prioritize atmosphere over zero-friction, door-to-door car access.</p>
            </div>
            <div>
              <div class="text-[11px] font-semibold tracking-[0.15em] uppercase mb-4 border-b border-black/10 pb-2">The Real Variable</div>
              <p class="text-on-surface-variant font-light leading-relaxed">The experience depends entirely on <strong>where you stay</strong>. A house at the very top of the old town feels completely different from a stay in the lower village.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- WHAT MATTERS MOST -->
      <section class="py-16 px-6 md:px-12 lg:px-24 max-w-[1600px] mx-auto">
        <div class="bg-white border border-[#E5E5E5] rounded-[24px] p-8 md:p-16">
          <div class="text-center max-w-2xl mx-auto mb-16">
            <h2 class="font-serif text-3xl md:text-5xl mb-6">What Matters Most</h2>
            <p class="text-on-surface-variant font-light text-lg">Forget the mythology of "impossible parking." Focus on these three practical realities instead.</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
            <div class="space-y-4">
              <div class="w-10 h-10 rounded-full bg-surface flex items-center justify-center mb-6">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
              </div>
              <h3 class="font-medium text-lg">Position Over Proximity</h3>
              <p class="text-on-surface-variant font-light text-sm leading-relaxed">The absolute nearest parking space matters less than the steepness of the walk. A slightly longer flat walk is always better than a short, vertical climb with luggage.</p>
            </div>
            <div class="space-y-4">
              <div class="w-10 h-10 rounded-full bg-surface flex items-center justify-center mb-6">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
              </div>
              <h3 class="font-medium text-lg">The Daily Rhythm</h3>
              <p class="text-on-surface-variant font-light text-sm leading-relaxed">Midday is dense with day-trippers. Early mornings and evenings are calm. If your stay is a base for constant midday in-and-out driving, you will feel more friction.</p>
            </div>
            <div class="space-y-4">
              <div class="w-10 h-10 rounded-full bg-surface flex items-center justify-center mb-6">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 0 1 21.75 8.25Z"/></svg>
              </div>
              <h3 class="font-medium text-lg">The Walking Reality</h3>
              <p class="text-on-surface-variant font-light text-sm leading-relaxed">You will walk. You will climb stairs. Frigiliana is a pedestrian-first environment. Embrace this as part of the charm, not a logistical failure.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- STAY MODELS -->
      <section class="py-16 px-6 md:px-12 lg:px-24 max-w-[1600px] mx-auto">
        <div class="mb-12">
          <h2 class="font-serif text-3xl md:text-5xl mb-4">The Stay Models</h2>
          <p class="text-on-surface-variant font-light text-lg max-w-xl">How your choice of location dictates your daily movement.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="border border-[#E5E5E5] bg-white p-8 flex flex-col">
            <div class="mb-8">
              <svg class="w-6 h-6 mb-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5"/></svg>
              <h3 class="font-serif text-2xl mb-2">High Old Town</h3>
              <p class="text-on-surface-variant font-light text-sm">Maximum atmosphere, maximum effort.</p>
            </div>
            <div class="mt-auto space-y-4">
              <div class="flex justify-between items-center border-t border-[#E5E5E5] pt-4">
                <span class="text-[11px] uppercase tracking-wider text-muted">Friction</span>
                <span class="text-sm font-medium">High</span>
              </div>
              <div class="flex justify-between items-center border-t border-[#E5E5E5] pt-4">
                <span class="text-[11px] uppercase tracking-wider text-muted">Car Access</span>
                <span class="text-sm font-medium">None (Walk only)</span>
              </div>
            </div>
          </div>

          <div class="border border-black bg-black text-white p-8 flex flex-col relative overflow-hidden">
            <div class="absolute top-0 right-0 bg-white text-black text-[10px] font-bold uppercase tracking-widest px-3 py-1 m-4">The Balance</div>
            <div class="mb-8">
              <svg class="w-6 h-6 mb-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
              <h3 class="font-serif text-2xl mb-2">Lower Village</h3>
              <p class="text-faint font-light text-sm">Historic character without the extreme climb.</p>
            </div>
            <div class="mt-auto space-y-4">
              <div class="flex justify-between items-center border-t border-white/20 pt-4">
                <span class="text-[11px] uppercase tracking-wider text-faint">Friction</span>
                <span class="text-sm font-medium">Moderate</span>
              </div>
              <div class="flex justify-between items-center border-t border-white/20 pt-4">
                <span class="text-[11px] uppercase tracking-wider text-faint">Car Access</span>
                <span class="text-sm font-medium">Nearby / Drop-off</span>
              </div>
            </div>
          </div>

          <div class="border border-[#E5E5E5] bg-white p-8 flex flex-col">
            <div class="mb-8">
              <svg class="w-6 h-6 mb-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/></svg>
              <h3 class="font-serif text-2xl mb-2">Countryside Edge</h3>
              <p class="text-on-surface-variant font-light text-sm">Space and ease, but disconnected from the core.</p>
            </div>
            <div class="mt-auto space-y-4">
              <div class="flex justify-between items-center border-t border-[#E5E5E5] pt-4">
                <span class="text-[11px] uppercase tracking-wider text-muted">Friction</span>
                <span class="text-sm font-medium">Low</span>
              </div>
              <div class="flex justify-between items-center border-t border-[#E5E5E5] pt-4">
                <span class="text-[11px] uppercase tracking-wider text-muted">Car Access</span>
                <span class="text-sm font-medium">Direct</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- FIT / NOT FIT -->
      <section class="py-16 px-6 md:px-12 lg:px-24 max-w-[1600px] mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 border border-[#E5E5E5] bg-white">
          <div class="p-8 md:p-16 border-b lg:border-b-0 lg:border-r border-[#E5E5E5]">
            <h3 class="font-serif text-2xl md:text-3xl mb-8">Frigiliana fits well if…</h3>
            <ul class="space-y-6">
              <li class="flex items-start gap-4">
                <svg class="w-5 h-5 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                <div><div class="font-medium mb-1">Atmosphere is your priority</div><div class="text-on-surface-variant font-light text-sm">You value historic charm over absolute logistical perfection.</div></div>
              </li>
              <li class="flex items-start gap-4">
                <svg class="w-5 h-5 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                <div><div class="font-medium mb-1">You don't mind walking</div><div class="text-on-surface-variant font-light text-sm">A 5–10 minute walk from car to door feels acceptable.</div></div>
              </li>
              <li class="flex items-start gap-4">
                <svg class="w-5 h-5 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                <div><div class="font-medium mb-1">You prefer calm evenings</div><div class="text-on-surface-variant font-light text-sm">You want to be based where you dine and relax, driving mainly for day trips.</div></div>
              </li>
            </ul>
          </div>
          <div class="p-8 md:p-16 bg-surface">
            <h3 class="font-serif text-2xl md:text-3xl mb-8 text-muted">Consider the coast if…</h3>
            <ul class="space-y-6">
              <li class="flex items-start gap-4">
                <svg class="w-5 h-5 shrink-0 mt-0.5 text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
                <div><div class="font-medium text-muted mb-1">You need zero-friction access</div><div class="text-hint font-light text-sm">You want to park directly outside your front door every time.</div></div>
              </li>
              <li class="flex items-start gap-4">
                <svg class="w-5 h-5 shrink-0 mt-0.5 text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
                <div><div class="font-medium text-muted mb-1">Mobility is a concern</div><div class="text-hint font-light text-sm">Steep inclines or stairs present a physical challenge for your group.</div></div>
              </li>
              <li class="flex items-start gap-4">
                <svg class="w-5 h-5 shrink-0 mt-0.5 text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
                <div><div class="font-medium text-muted mb-1">You are beach-obsessed</div><div class="text-hint font-light text-sm">You plan to drive to the beach multiple times a day.</div></div>
              </li>
            </ul>
          </div>
        </div>
      </section>

      <!-- AMARA CTA -->
      <section class="py-16 px-6 md:px-12 lg:px-24 max-w-[1600px] mx-auto mb-12">
        <div class="bg-black text-white p-8 md:p-16 text-center">
          <span class="text-[11px] font-semibold tracking-[0.15em] uppercase text-faint mb-6 block">The AMARA Approach</span>
          <h2 class="font-serif text-3xl md:text-5xl mb-6 max-w-3xl mx-auto leading-tight">
            We select stays that balance village charm with manageable daily movement.
          </h2>
          <p class="text-faint font-light text-lg max-w-2xl mx-auto mb-10">
            If you want the beauty of Frigiliana without the extreme logistical friction, explore our curated collection in the lower village.
          </p>
          <a href="#" class="inline-flex justify-center items-center gap-2 px-8 py-4 bg-white text-black text-sm font-medium hover:bg-gray-100 transition-colors">
            Explore AMARA Stays
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
          </a>
        </div>
      </section>

    </div>
  </div>
</LocationAuthorityLayout>