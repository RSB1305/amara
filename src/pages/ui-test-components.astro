---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FaqAccordion from '../components/FaqAccordion.astro';

const seo = {
  version: '2026-03-23-ui-test-components',
  pageType: 'C',
  entityKey: 'amara-brand',
  languages: {
    en: {
      title: 'AMARA Component Test Surface',
      description: 'Visual test page for AMARA modules and design decisions.',
      robots: 'noindex, nofollow',
      canonical: 'auto'
    }
  }
};

const summaryItems = [
  { label: 'Address', value: 'Calle Chorruelo 5, 29788 Frigiliana' },
  { label: 'Best for', value: 'Editorial calm, trust and arrival clarity' },
  { label: 'Visual mode', value: 'Warm, spacious, text-led' },
  { label: 'Decision use', value: 'Keep, adapt or discard modules quickly' }
];

const trustPrinciples = [
  {
    title: 'Prepared for real stays',
    text: 'Comfort and daily usefulness come first, rather than staging for photos.'
  },
  {
    title: 'Consistency over promises',
    text: 'What the guest sees in advance should match what they actually find.'
  },
  {
    title: 'Calm execution',
    text: 'The page language and component rhythm should feel quiet, not promotional.'
  }
];

const faqSteps = [
  {
    num: '01',
    headline: 'Editorial hierarchy',
    text: 'Large serif headlines, compact uppercase labels and generous white space create the core rhythm.'
  },
  {
    num: '02',
    headline: 'Utility clarity',
    text: 'Information blocks should stay short, legible and quietly structured, without heavy card behavior.'
  },
  {
    num: '03',
    headline: 'Trust expression',
    text: 'The brand feels strongest when the design stays restrained, warm and highly readable.'
  }
];

const faqItems = [
  {
    question: 'Should this page behave like production?',
    answer: 'No. This is a visual test surface for comparing modules and composition decisions only.'
  },
  {
    question: 'Can modules be mixed more freely here?',
    answer: 'Yes. The purpose is to see multiple AMARA patterns on one page before deciding what belongs in production.'
  },
  {
    question: 'What should we evaluate first?',
    answer: 'Headline hierarchy, spacing rhythm, density of information, and whether each module feels calm or too loud.'
  }
];
---

<BaseLayout seo={seo}>
  <Hero imageSrc="/images/hero-frigiliana.jpg" imageAlt="AMARA component test hero">
    <span class="label-md text-primary mb-8 block font-bold">AMARA Visual Test</span>
    <h1 class="text-[clamp(3.4rem,9vw,6rem)] leading-[0.9] font-headline font-light italic text-on-surface mb-10 tracking-tighter">
      Component Surface <br /> for Fast Decisions
    </h1>
    <div class="pl-10 border-l border-primary/20 max-w-xl mb-14">
      <p class="text-on-surface-variant text-lg leading-relaxed font-body">
        A single test page to review editorial, utility and trust-oriented AMARA
        modules together in one calm, comparable flow.
      </p>
    </div>
  </Hero>

  <section class="max-w-screen-2xl mx-auto px-12 py-24 border-t border-outline-variant/5">
    <div class="max-w-4xl mb-12">
      <span class="label-md text-primary mb-5 block font-bold">Utility Summary Panel</span>
      <h2 class="font-headline text-4xl md:text-5xl italic text-on-surface tracking-tight mb-6">
        Fast orientation at a glance
      </h2>
      <p class="text-on-surface-variant text-lg leading-relaxed italic max-w-2xl">
        This block is intentionally compact and practical. It helps evaluate how much
        utility information AMARA can show without breaking the calm editorial tone.
      </p>
    </div>

    <div class="max-w-3xl border border-outline-variant/15 bg-surface-container-low p-8 md:p-10">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
        {summaryItems.map((item) => (
          <div class="border-b border-outline-variant/10 pb-5 last:border-b-0 md:last:border-b md:[&:nth-last-child(-n+2)]:border-b-0">
            <span class="text-[10px] uppercase tracking-[0.2em] text-outline font-bold block mb-2">
              {item.label}
            </span>
            <p class="text-on-surface leading-relaxed">{item.value}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="max-w-screen-2xl mx-auto px-12 py-32 border-t border-outline-variant/5">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 lg:gap-32">
      <div>
        <span class="label-md text-primary mb-6 block font-bold">Numbered Editorial Steps</span>
        <h2 class="font-headline text-5xl md:text-6xl italic text-on-surface tracking-tight mb-12">
          A calm decision sequence
        </h2>
      </div>

      <div class="space-y-14">
        {faqSteps.map((step) => (
          <div class="flex gap-8 items-start">
            <span class="text-[56px] font-headline italic leading-none text-outline-variant opacity-60 select-none">
              {step.num}
            </span>
            <div class="pt-2">
              <h3 class="font-bold text-[11px] uppercase tracking-[0.2em] text-on-surface mb-3">
                {step.headline}
              </h3>
              <p class="text-on-surface-variant leading-relaxed text-[15px] max-w-md">
                {step.text}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="max-w-screen-2xl mx-auto px-12 py-32 border-t border-outline-variant/5">
    <div class="max-w-3xl mb-14">
      <span class="label-md text-primary mb-6 block font-bold">Trust Principles</span>
      <h2 class="font-headline text-5xl md:text-6xl italic text-on-surface tracking-tight mb-8">
        What should feel unmistakably AMARA
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      {trustPrinciples.map((principle) => (
        <div class="border-l border-outline-variant/20 pl-8 py-2">
          <h3 class="text-2xl font-headline italic text-on-surface mb-5">
            {principle.title}
          </h3>
          <p class="text-on-surface-variant text-base leading-relaxed opacity-85">
            {principle.text}
          </p>
        </div>
      ))}
    </div>
  </section>

  <section class="py-32 bg-on-surface text-surface px-12">
    <div class="max-w-4xl mx-auto text-center">
      <div class="text-primary-fixed-dim text-6xl mb-8 font-headline">"</div>
      <blockquote class="font-headline text-4xl md:text-5xl italic font-light leading-tight mb-10">
        The strongest version is usually the quietest one that still feels precise.
      </blockquote>
      <cite class="uppercase tracking-[0.3em] text-[11px] text-surface/60 not-italic font-bold">
        AMARA Design Review Note
      </cite>
    </div>
  </section>

  <section class="max-w-screen-2xl mx-auto px-12 py-32 border-t border-outline-variant/5">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-16 items-center">
      <div class="md:col-span-5">
        <div class="aspect-[4/5] bg-surface-container-high overflow-hidden">
          <img
            src="/images/hero-frigiliana.jpg"
            alt="Editorial split test"
            class="w-full h-full object-cover grayscale-[10%]"
            loading="lazy"
          />
        </div>
      </div>

      <div class="md:col-span-7">
        <span class="label-md text-primary mb-6 block font-bold">Image + Text Editorial Split</span>
        <h2 class="font-headline text-5xl md:text-6xl italic text-on-surface tracking-tight mb-8">
          One image, one argument, enough breathing room
        </h2>
        <p class="text-on-surface-variant text-lg leading-loose max-w-2xl mb-8">
          This split is here to test whether AMARA feels strongest when image treatment
          stays simple and the text column carries the real editorial weight.
        </p>
        <p class="text-on-surface-variant text-lg leading-loose max-w-2xl italic opacity-80">
          It should read as premium, not busy. If it starts feeling like a card grid,
          the module is too loud for the system.
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-screen-lg mx-auto px-12 py-24 border-t border-outline-variant/10">
    <div class="text-center">
      <span class="label-md text-primary mb-5 block font-bold">Calm CTA</span>
      <h2 class="font-headline text-4xl md:text-5xl italic text-on-surface tracking-tight mb-6">
        Keep the next step understated
      </h2>
      <p class="text-on-surface-variant text-lg leading-relaxed max-w-2xl mx-auto mb-10">
        This CTA is intentionally soft. It should invite action without breaking the
        editorial restraint of the page.
      </p>
      <p class="text-on-surface text-lg leading-relaxed">
        <a href="#" class="underline decoration-outline-variant underline-offset-4 hover:text-primary transition-colors">
          Check availability
        </a>
        <span class="mx-3 text-outline">·</span>
        <a href="#" class="underline decoration-outline-variant underline-offset-4 hover:text-primary transition-colors">
          Compare modules
        </a>
        <span class="mx-3 text-outline">·</span>
        <a href="#" class="underline decoration-outline-variant underline-offset-4 hover:text-primary transition-colors">
          Review trust direction
        </a>
      </p>
    </div>
  </section>

  <FaqAccordion
    arrivalTitle="Review Sequence"
    steps={faqSteps}
    faqTitle="Decision FAQ"
    items={faqItems}
  />
</BaseLayout>
