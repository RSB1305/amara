---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import UtilitySummaryPanel from '../components/UtilitySummaryPanel.astro';

const seo = {
  version: '2026-03-23-ui-patterns',
  pageType: 'C',
  entityKey: 'amara-brand',
  languages: {
    en: {
      title: 'AMARA UI Patterns Test',
      description: 'Visual pattern page for AMARA design review.',
      robots: 'noindex, nofollow',
      canonical: 'auto'
    }
  }
};

const utilityItems = [
  {
    label: 'Address',
    value: ['Calle Chorruelo 5', '29788 Frigiliana']
  },
  {
    label: 'Drop-off',
    value: 'Avenida Carlos Cano 42',
    note: 'Usually the easiest arrival point for first-time guests.'
  },
  {
    label: 'Walking distance',
    value: 'approx. 4 min · 150 m uphill'
  },
  {
    label: 'Parking',
    value: 'Main underground village parking'
  },
  {
    label: 'Contact',
    value: ['+34 952 533 131', 'Emergency: 112']
  }
];

const reviewSteps = [
  {
    num: '01',
    headline: 'Arrival',
    text: 'The guest should understand the first move immediately, without scanning a crowded layout.'
  },
  {
    num: '02',
    headline: 'Access',
    text: 'Walking, luggage and structure should be explained calmly, with enough hierarchy to feel premium.'
  },
  {
    num: '03',
    headline: 'Final note',
    text: 'The page should close with confidence and clarity, not with louder calls to action.'
  }
];

const trustPrinciples = [
  'Prepared for real stays',
  'Calm, not stimulation',
  'Direct responsibility',
  'Privacy respected'
];

const faqItems = [
  {
    question: 'What is this page for?',
    answer: 'It is a decision surface to review multiple AMARA patterns together on one page.'
  },
  {
    question: 'Should every block survive into production?',
    answer: 'No. The point is to compare modules quickly and decide what to keep, adapt or remove.'
  },
  {
    question: 'What matters most in this review?',
    answer: 'Rhythm, hierarchy, calmness, and whether the modules feel coherent when stacked together.'
  }
];
---

<BaseLayout seo={seo}>
  <div class="am-patterns">
    <Hero imageSrc="/images/hero-frigiliana.jpg" imageAlt="AMARA patterns test hero">
      <span class="label-md text-primary mb-8 block font-bold">AMARA Pattern Review</span>
      <h1 class="text-[clamp(3.3rem,9vw,5.8rem)] leading-[0.9] font-headline font-light italic text-on-surface mb-8 tracking-tighter">
        A Single Page <br /> to Compare the System
      </h1>
      <p class="text-on-surface-variant text-xl italic opacity-80 mb-4">
        Editorial · Utility · Trust
      </p>
      <div class="pl-10 border-l border-primary/20 max-w-xl mb-12">
        <p class="text-on-surface-variant text-lg leading-relaxed font-body">
          This page is only here to let us look at several AMARA module types together,
          without touching production decisions too early.
        </p>
      </div>
      <a
        href="#summary"
        class="inline-block bg-primary text-on-primary px-10 py-4 text-[11px] uppercase tracking-[0.2em] font-bold hover:bg-primary-container transition-all"
      >
        Review Modules
      </a>
    </Hero>

    <section id="summary" class="am-patterns__section max-w-screen-2xl mx-auto px-12">
      <div class="max-w-3xl mb-12">
        <span class="am-kicker">Utility Summary Panel</span>
        <h2 class="am-section-title">Fast orientation, quietly structured</h2>
      </div>
      <div class="max-w-3xl">
        <UtilitySummaryPanel title="Arrival Summary" items={utilityItems} />
      </div>
    </section>

    <section class="am-patterns__section max-w-screen-2xl mx-auto px-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 lg:gap-32 items-start">
        <div>
          <span class="am-kicker">Numbered Editorial Steps</span>
          <h2 class="am-section-title">A simple three-step test block</h2>
        </div>
        <div class="space-y-14">
          {reviewSteps.map((step) => (
            <div class="flex gap-8 items-start">
              <span class="text-[56px] font-headline italic leading-none text-outline-variant opacity-60 select-none">
                {step.num}
              </span>
              <div class="pt-2">
                <h3 class="font-bold text-[11px] uppercase tracking-[0.2em] text-on-surface mb-3">
                  {step.headline}
                </h3>
                <p class="text-on-surface-variant leading-relaxed text-[15px] max-w-md">
                  {step.text}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="am-patterns__section max-w-screen-2xl mx-auto px-12">
      <div class="max-w-3xl mb-14">
        <span class="am-kicker">Trust Principles</span>
        <h2 class="am-section-title">Text-first signals of the AMARA tone</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-10">
        {trustPrinciples.map((principle) => (
          <div class="border-l border-outline-variant/20 pl-8 py-2">
            <h3 class="text-2xl font-headline italic text-on-surface mb-4">{principle}</h3>
            <p class="text-on-surface-variant text-base leading-relaxed">
              This principle should feel visible in tone, spacing and restraint rather than through loud decoration.
            </p>
          </div>
        ))}
      </div>
    </section>

    <section class="py-32 bg-on-surface text-surface px-12">
      <div class="max-w-4xl mx-auto text-center">
        <div class="text-primary-fixed-dim text-6xl mb-8 font-headline">"</div>
        <blockquote class="font-headline text-4xl md:text-5xl italic font-light leading-tight mb-10">
          The page feels premium when nothing needs to shout.
        </blockquote>
        <cite class="uppercase tracking-[0.3em] text-[11px] text-surface/60 not-italic font-bold">
          AMARA Review Principle
        </cite>
      </div>
    </section>

    <section class="am-patterns__section max-w-screen-2xl mx-auto px-12">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-16 items-center">
        <div class="md:col-span-5">
          <div class="aspect-[4/5] bg-surface-container-high overflow-hidden">
            <img
              src="/images/hero-frigiliana.jpg"
              alt="Editorial split test image"
              class="w-full h-full object-cover grayscale-[10%]"
              loading="lazy"
            />
          </div>
        </div>
        <div class="md:col-span-7">
          <span class="am-kicker">Image + Text Editorial Split</span>
          <h2 class="am-section-title">One image, one argument, enough room to breathe</h2>
          <p class="am-body mb-6">
            This section exists to test whether the image can stay restrained while the text carries the real editorial value.
          </p>
          <p class="am-body am-patterns__muted">
            If this starts feeling like a promo block or a card-based marketing layout, the module is too loud for AMARA.
          </p>
        </div>
      </div>
    </section>

    <section class="am-patterns__section max-w-screen-lg mx-auto px-12 border-t border-outline-variant/10 pt-20">
      <div class="text-center">
        <span class="am-kicker">Calm CTA</span>
        <h2 class="am-section-title">Keep the next step understated</h2>
        <p class="am-body max-w-2xl mx-auto mb-10">
          The call to action should feel like a natural next move, not like pressure.
        </p>
        <p class="text-on-surface text-lg leading-relaxed">
          <a href="#" class="underline decoration-outline-variant underline-offset-4 hover:text-primary transition-colors">
            Check availability
          </a>
          <span class="mx-3 text-outline">·</span>
          <a href="#" class="underline decoration-outline-variant underline-offset-4 hover:text-primary transition-colors">
            Compare patterns
          </a>
        </p>
      </div>
    </section>

    <FaqAccordion
      arrivalTitle="Review Sequence"
      steps={reviewSteps}
      faqTitle="Pattern FAQ"
      items={faqItems}
    />
  </div>
</BaseLayout>

<style>
  .am-patterns__section {
    padding-top: 8rem;
    padding-bottom: 8rem;
    border-top: 1px solid rgb(210 197 179 / 0.08);
  }

  .am-section-title {
    margin: 0 0 1.75rem;
    font-family: "Newsreader", serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-style: italic;
    font-weight: 400;
    line-height: 0.98;
    letter-spacing: -0.03em;
    color: var(--color-on-surface);
  }

  .am-body {
    margin: 0;
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 1.05rem;
    line-height: 1.85;
    color: var(--color-on-surface-variant);
  }

  .am-patterns__muted {
    font-style: italic;
    opacity: 0.82;
  }

  @media (max-width: 48rem) {
    .am-patterns__section {
      padding-top: 5rem;
      padding-bottom: 5rem;
    }

    .am-body {
      font-size: 1rem;
      line-height: 1.8;
    }
  }
</style>
