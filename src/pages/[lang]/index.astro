---
// src/pages/[lang]/index.astro
import LocationAuthorityLayout from '../../layouts/LocationAuthorityLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Hero from '../../components/Hero.astro';
import Weather from '../../components/Weather.astro';
import EssenceGrid from '../../components/EssenceGrid.astro';
import PhotoShow from '../../components/PhotoShow.astro';
import StayDecision from '../../components/StayDecision.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import { resolveLink } from '../../lib/linkResolver';
import { normalizeLanguage } from '../../lib/seo/resolve-seo-head';
import type { AmaraAuthoringSeo, AmaraLanguage } from '../../types/seo';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'de' } },
    { params: { lang: 'nl' } },
    { params: { lang: 'sv' } }
  ];
}

const { lang } = Astro.params;
const currentLang = normalizeLanguage(lang as AmaraLanguage);

const seo: AmaraAuthoringSeo = {
  version: "2026-03-21-v3.0",
  pageType: "A",
  languages: {
    en: { title: "Frigiliana | The Authority Guide", description: "Discover the authentic heart of Andalusia.", robots: "index, follow", canonical: "auto" },
    de: { title: "Frigiliana | Die Seele der weißen Dörfer", description: "Entdecke das authentische Herz Andalusiens.", robots: "index, follow", canonical: "auto" },
    es: { title: "Frigiliana | La Guía de Autoridad", description: "Descubre el corazón auténtico de Andalucía.", robots: "index, follow", canonical: "auto" },
    nl: { title: "Frigiliana | De ziel van de witte dorpen", description: "Ontdek het authentieke hart van Andalusië.", robots: "index, follow", canonical: "auto" },
    sv: { title: "Frigiliana | Den Officiella Guiden", description: "Upptäck Andalusiens autentiska hjärta.", robots: "index, follow", canonical: "auto" }
  },
  ogImage: "/images/frigiliana-hero-og.jpg"
};

const copy = {
  nav: {
    brand: { en: "Frigiliana", de: "Frigiliana", es: "Frigiliana", nl: "Frigiliana", sv: "Frigiliana" },
    links: [
      { token: "explore_hub", label: { en: "Explore", de: "Entdecken", es: "Explorar", nl: "Ontdekken", sv: "Utforska" } },
      { token: "weather_frigiliana", label: { en: "Climate", de: "Klima", es: "Clima", nl: "Klimaat", sv: "Klimat" } },
      { token: "journal", label: { en: "Journal", de: "Journal", es: "Diario", nl: "Journal", sv: "Journal" } }
    ]
  },
  hero: {
    eyebrow: { en: "The Axarquía Jewel", de: "Das Juwel der Axarquía", es: "La joya de la Axarquía", nl: "Het juweel van Axarquía", sv: "Axarquías juvel" },
    h1: { en: "The Soul of <br/> White Villages", de: "Die Seele der <br/> weißen Dörfer", es: "El alma de los <br/> pueblos blancos", nl: "De ziel van de <br/> witte dorpen", sv: "De vita byarnas <br/> själ" },
    body: { en: "Nestled in the folds of the Almijara mountains, Frigiliana exists as a timeless dialogue between Moorish geometry and Mediterranean light.", de: "In den Falten des Almijara-Gebirges gelegen, ist Frigiliana ein zeitloser Dialog zwischen maurischer Geometrie und mediterranem Licht.", es: "Enclavada en los pliegues de la sierra Almijara, Frigiliana es un diálogo atemporal entre la geometría morisca y la luz mediterránea.", nl: "Gelegen in de plooien van het Almijara-gebergte, is Frigiliana een tijdloze dialoog zwischen Moorse geometrie en mediterraan licht.", sv: "Inbäddat i Almijara-bergens veck är Frigiliana en zeitlös dialog mellan maurisk geometri och medelhavsljus." },
    ctaMain: { en: "Explore The Barrio", de: "Das Viertel erkunden", es: "Explorar el Barrio", nl: "Verken de Barrio", sv: "Utforska kvarteret" },
    ctaAlt: { en: "The Guide", de: "Zum Guide", es: "La Guía", nl: "De Gids", sv: "Guiden" }
  },
  essence: {
    eyebrow: { en: "The Essence of Living", de: "Die Essenz des Lebens", es: "La esencia de vivir", nl: "De essentie van het leven", sv: "Livets essens" },
    title: { en: "Identity & Light", de: "Identität & Licht", es: "Identidad y luz", nl: "Identiteit & Licht", sv: "Identitet & ljus" },
    intro: { en: "To inhabit Frigiliana is to understand the vertical rhythm of history.", de: "Frigiliana zu bewohnen bedeutet, den vertikalen Rhythmus der Geschichte zu verstehen.", es: "Habitar Frigiliana es comprender el ritmo vertical de la historia.", nl: "Wonen in Frigiliana is het verticale ritme van de geschiedenis begrijpen.", sv: "Att bo i Frigiliana är att förstå historiens vertikala rytm." },
    items: [
      { kicker: { en: "Perspective", de: "Perspektive", es: "Perspectiva", nl: "Perspectief", sv: "Perspektiv" }, headline: { en: "Moorish Urban Fabric", de: "Maurisches Stadtgefüge", es: "Trama urbana mudéjar", nl: "Moors stedelijk weefsel", sv: "Maurisk stadsstruktur" }, text: { en: "Labyrinth of white and stone.", de: "Labyrinth aus Weiß und Stein.", es: "Laberinto de blanco y piedra.", nl: "Labyrint van wit en steen.", sv: "Labyrint av vitt och sten." }, imageSrc: "/images/essence-1.jpg", token: "explore_hub", linkLabel: { en: "Explore", de: "Erkunden", es: "Explorar", nl: "Ontdek", sv: "Utforska" } },
      { kicker: { en: "Atmosphere", de: "Atmosphäre", es: "Atmósfera", nl: "Sfeer", sv: "Atmosfär" }, headline: { en: "300 Days of Sun", de: "300 Tage Sonne", es: "300 días de sol", nl: "300 dagen zon", sv: "300 dagar av sol" }, text: { en: "The microclimate ensures a perpetual spring.", de: "Das Mikroklima sorgt für einen ewigen Frühling.", es: "El microclima sorgt für einen ewigen Frühling.", nl: "Het microklimaat sorgt voor een eeuwige lente.", sv: "Mikroklimatet garanterar en ständig vår." }, imageSrc: "/images/essence-2.jpg" },
      { kicker: { en: "Materiality", de: "Materialität", es: "Materialidad", nl: "Materialiteit", sv: "Materialitet" }, headline: { en: "Whitewashed", de: "Weiß gekalkt", es: "Encalado", nl: "Witgekalkt", sv: "Vitkalkat" }, text: { en: "Mediterranean light dialogue.", de: "Mediterraner Lichtdialog.", es: "Diálogo de luz mediterráneo.", nl: "Mediterrane lichtdialoog.", sv: "Medelhavsljusdialog." } },
      { kicker: { en: "Heritage", de: "Erbe", es: "Patrimonio", nl: "Erfgoed", sv: "Arv" }, headline: { en: "Miel de Caña", de: "Zuckerrohrhonig", es: "Miel de caña", nl: "Suikerriethoning", sv: "Sockerrörshonung" }, text: { en: "European tradition.", de: "Europäische Tradition.", es: "Tradición europea.", nl: "Europese traditie.", sv: "Europeisk tradition." }, imageSrc: "/images/essence-3.jpg" }
    ]
  },
  climate: {
    h2: { en: "The Microclimate", de: "Das Mikroklima", es: "El microclima", nl: "Het microklimaat", sv: "Mikroklimatet" },
    text: { en: "Frigiliana exists in a privileged equilibrium.", de: "Frigiliana befindet sich in einem privilegierten Gleichgewicht.", es: "Frigiliana existe en un equilibrio privilegiado.", nl: "Frigiliana bevindt zich in een bevoorrecht evenwicht.", sv: "Frigiliana befinner sig i en privilegierad jämvikt." }
  },
  gallery: {
    eyebrow: { en: "Architectural Study", de: "Architekturstudie", es: "Estudio Arquitectónico", nl: "Architecturale Studie", sv: "Arkitektonisk Studie" },
    title: { en: "Mudejar Geometry", de: "Maurische Geometrie", es: "Geometría Mudéjar", nl: "Moorse Geometrie", sv: "Maurisk Geometri" },
    items: [
      { src: '/images/gallery-1.jpg', alt: { en: "Indigo", de: "Indigo", es: "Índigo", nl: "Indigo", sv: "Indigo" }, caption: { en: "Blue doors of Calle Real", de: "Die blauen Türen der Calle Real", es: "Las puertas azules", nl: "De blauwe deuren", sv: "De blå dörrarna" } },
      { src: '/images/gallery-2.jpg', alt: { en: "Sierra", de: "Sierra", es: "Sierra", nl: "Sierra", sv: "Sierra" }, caption: { en: "Sierra Almijara", de: "Sierra Almijara", es: "Sierra Almijara", nl: "Sierra Almijara", sv: "Sierra Almijara" } }
    ]
  },
  decision: {
    eyebrow: { en: "Stay Decision", de: "Entscheidungshilfe", es: "Decisión", nl: "Beslissing", sv: "Beslut" },
    title: { en: "Is Frigiliana for you?", de: "Ist Frigiliana richtig für Sie?", es: "¿Para usted?", nl: "Iets voor jou?", sv: "För dig?" },
    profiles: [
      { title: { en: "Couples", de: "Paare", es: "Parejas", nl: "Koppels", sv: "Par" }, description: { en: "Architectural silence.", de: "Architektonische Stille.", es: "Silencio.", nl: "Stilte.", sv: "Tystnad." }, suitability: { en: "Highest", de: "Exzellent", es: "Máxima", nl: "Hoogste", sv: "Högsta" } }
    ]
  },
  faq: {
    arrivalTitle: { en: "The Arrival", de: "Die Ankunft", es: "La Llegada", nl: "De Aankomst", sv: "Ankomsten" },
    steps: [
      { 
        num: "01", 
        h: { en: "Gateways", de: "Anreise", es: "Puertas", nl: "Poorten", sv: "Portar" }, 
        t: { en: "Malaga Airport (AGP) is the primary gateway, located 50 minutes to the West via the A-7.", de: "Der Flughafen Malaga (AGP) ist das Haupttor, 50 Minuten westlich über die A-7.", es: "El aeropuerto de Málaga (AGP) es la puerta principal, a 50 minutos.", nl: "Luchthaven Malaga (AGP) is de belangrijkste poort.", sv: "Malaga flygplats (AGP) är huvudporten." } 
      },
      { 
        num: "02", 
        h: { en: "Transportation", de: "Transport", es: "Transporte", nl: "Vervoer", sv: "Transport" }, 
        t: { en: "While public buses run frequently, a private vehicle is essential for exploring the Axarquía.", de: "Busse fahren oft, aber ein Auto ist für die Axarquía unerlässlich.", es: "Los autobuses funcionan, aber un coche es esencial.", nl: "Bussen rijden, maar een auto is essentieel.", sv: "Bussar går, men bil är nödvändigt." } 
      },
      { 
        num: "03", 
        h: { en: "The Ascent", de: "Der Aufstieg", es: "El Ascenso", nl: "De Klim", sv: "Klättringen" }, 
        t: { en: "Frigiliana is divided into Barrio Nuevo and Alto. Prepare for steep inclines.", de: "Frigiliana ist geteilt. Stellen Sie sich auf steile Gassen ein.", es: "Frigiliana está dividida. Prepárate para las cuestas.", nl: "Frigiliana is verdeeld. Bereid je voor op hellingen.", sv: "Frigiliana är uppdelad. Förbered dig på backar." } 
      }
    ],
    faqTitle: { en: "Dispatches & FAQ", de: "Depeschen & FAQ", es: "Despachos y FAQ", nl: "Berichten & FAQ", sv: "Meddelanden & FAQ" },
    items: [
      { q: { en: "When is the best time to visit?", de: "Beste Reisezeit?", es: "¿Mejor época?", nl: "Beste reistijd?", sv: "Bästa tiden?" }, a: { en: "Late May and early October offer perfect light.", de: "Ende Mai und Anfang Oktober bieten perfektes Licht.", es: "Mayo y octubre son perfectos.", nl: "Mei en oktober zijn perfect.", sv: "Maj och oktober är perfekta." } }
    ]
  },
  footer: {
    brand: { en: "Frigiliana Editorial", de: "Frigiliana Editorial", es: "Editorial", nl: "Redactie", sv: "Redaktion" },
    rights: { en: "All rights reserved.", de: "Alle Rechte vorbehalten.", es: "Reservados", nl: "Voorbehouden", sv: "Förbehållna" },
    nav: [
      { token: 'journal', label: { en: "Journal", de: "Journal", es: "Diario", nl: "Journal", sv: "Journal" } },
      { token: 'contact', label: { en: "Contact", de: "Kontakt", es: "Contacto", nl: "Contact", sv: "Kontakt" } },
      { token: 'archive', label: { en: "Archive", de: "Archiv", es: "Archivo", nl: "Archief", sv: "Arkiv" } },
      { token: 'legal_notice', label: { en: "Privacy", de: "Datenschutz", es: "Privacidad", nl: "Privacy", sv: "Integritet" } }
    ]
  }
};

const c = {
  nav: { brand: copy.nav.brand[currentLang], links: copy.nav.links.map(l => ({ token: l.token, label: l.label[currentLang] })) },
  hero: { eyebrow: copy.hero.eyebrow[currentLang], h1: copy.hero.h1[currentLang], body: copy.hero.body[currentLang], ctaMain: copy.hero.ctaMain[currentLang], ctaAlt: copy.hero.ctaAlt[currentLang] },
  essence: { eyebrow: copy.essence.eyebrow[currentLang], title: copy.essence.title[currentLang], intro: copy.essence.intro[currentLang], items: copy.essence.items.map(item => ({ kicker: item.kicker[currentLang], headline: item.headline[currentLang], text: item.text[currentLang], imageSrc: item.imageSrc, imageAlt: item.headline[currentLang], href: item.token ? resolveLink(item.token, currentLang) : undefined, linkLabel: item.linkLabel ? item.linkLabel[currentLang] : undefined })) },
  climate: { h2: copy.climate.h2[currentLang], text: copy.climate.text[currentLang] },
  gallery: { eyebrow: copy.gallery.eyebrow[currentLang], title: copy.gallery.title[currentLang], images: copy.gallery.items.map(img => ({ src: img.src, alt: img.alt[currentLang] || img.alt.en, caption: img.caption[currentLang] || img.caption.en })) },
  decision: { eyebrow: copy.decision.eyebrow[currentLang], title: copy.decision.title[currentLang], profiles: copy.decision.profiles.map(p => ({ title: p.title[currentLang], description: p.description[currentLang], suitability: p.suitability[currentLang] })) },
 // Diesen Teil innerhalb von "const c = { ... }" ersetzen:
faq: { 
  arrivalTitle: copy.faq.arrivalTitle[currentLang],
  steps: copy.faq.steps.map(s => ({ 
    num: s.num, 
    headline: s.h[currentLang], 
    text: s.t[currentLang] 
  })),
  faqTitle: copy.faq.faqTitle[currentLang],
  items: copy.faq.items.map(item => ({ 
    question: item.q[currentLang], 
    answer: item.a[currentLang] 
  }))
},
  footer: { brand: copy.footer.brand[currentLang], rights: copy.footer.rights[currentLang], links: copy.footer.nav.map(link => ({ token: link.token, label: link.label[currentLang] })) }
};

/**
 * The homepage hero is the mobile LCP candidate, so the page defines a
 * responsive asset set here and lets the canonical Hero component render it.
 */
const heroImage = {
  src: '/images/hero-frigiliana-960.jpg',
  alt: 'Frigiliana hillside homes in afternoon light',
  width: 960,
  height: 641,
  sizes: '(max-width: 767px) calc(100vw - 3rem), (max-width: 1023px) 60vw, 40vw',
  sources: {
    webp: [
      { src: '/images/hero-frigiliana-640.webp', width: 640 },
      { src: '/images/hero-frigiliana-960.webp', width: 960 }
    ],
    fallback: [
      { src: '/images/hero-frigiliana-640.jpg', width: 640 },
      { src: '/images/hero-frigiliana-960.jpg', width: 960 }
    ]
  }
};
---

<LocationAuthorityLayout seo={seo} pageLang={currentLang}>
  
  <Navigation 
    currentLang={currentLang} 
    brandName={c.nav.brand} 
    links={c.nav.links} 
  />

  <Hero
    imageSrc={heroImage.src}
    imageAlt={heroImage.alt}
    imageWidth={heroImage.width}
    imageHeight={heroImage.height}
    imageSizes={heroImage.sizes}
    imageSources={heroImage.sources}
  >
    <span class="label-md text-primary mb-8 block font-bold">{c.hero.eyebrow}</span>
    <h1 class="text-[clamp(3.5rem,9vw,6rem)] leading-[0.9] font-headline font-light italic text-on-surface mb-10 tracking-tighter" set:html={c.hero.h1} />
    <div class="pl-10 border-l border-primary/20 max-w-lg mb-14"><p class="text-on-surface-variant text-lg leading-relaxed font-body">{c.hero.body}</p></div>
    <div class="flex flex-wrap gap-8">
      <a href={resolveLink('explore_hub', currentLang)} class="bg-primary text-on-primary px-12 py-5 text-[11px] uppercase tracking-[0.2em] font-bold hover:bg-primary-container transition-all">{c.hero.ctaMain}</a>
      <a href={resolveLink('arrival_guide', currentLang)} class="border border-outline-variant/30 text-on-surface px-12 py-5 text-[11px] uppercase tracking-[0.2em] font-bold hover:bg-surface-container-low transition-all">{c.hero.ctaAlt}</a>
    </div>
  </Hero>

  <EssenceGrid eyebrow={c.essence.eyebrow} title={c.essence.title} intro={c.essence.intro} items={c.essence.items} />

  <section class="max-w-screen-2xl mx-auto px-12 py-40 border-t border-outline-variant/5">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-24 items-center">
      <div class="md:col-span-7">
        <h2 class="font-headline text-5xl md:text-6xl italic mb-10 text-on-surface tracking-tight">{c.climate.h2}</h2>
        <p class="text-on-surface-variant text-xl leading-relaxed font-body max-w-xl italic opacity-80">{c.climate.text}</p>
      </div>
      <div class="md:col-span-5"><Weather lat={36.7908} lon={-3.8961} locationName="Frigiliana" /></div>
    </div>
  </section>

  <PhotoShow eyebrow={c.gallery.eyebrow} title={c.gallery.title} images={c.gallery.images} />
  <StayDecision eyebrow={c.decision.eyebrow} title={c.decision.title} profiles={c.decision.profiles} />
  
  <FaqAccordion 
    arrivalTitle={c.faq.arrivalTitle}
    steps={c.faq.steps}
    faqTitle={c.faq.faqTitle}
    items={c.faq.items} 
  />
  
</LocationAuthorityLayout>
