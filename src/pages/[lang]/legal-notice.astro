                  <li class={specsItemClass}><strong class="text-on-surface">Regionale Lizenz</strong> <span>VFT/MA/19212</span></li>
                  <li class={specsItemClass}><strong class="text-on-surface">Registrierung (NRUA)</strong> <span><code class="break-all font-mono text-sm text-on-surface">ESFCTU0000290130000818750000000000000000VUT/MA/192120</code></span></li>
