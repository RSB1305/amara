---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import { normalizeLanguage } from '../../lib/seo/resolve-seo-head';
import type { AmaraAuthoringSeo, AmaraLanguage } from '../../types/seo';

export function getStaticPaths() {
  return [
    { params: { lang: 'de' } },
    { params: { lang: 'es' } },
    { params: { lang: 'nl' } },
    { params: { lang: 'sv' } }
  ];
}

const { lang } = Astro.params;
const currentLang = normalizeLanguage(lang as AmaraLanguage);

const seo: AmaraAuthoringSeo = {
  version: '2026-03-24-legal-content-v1.0-C',
  pageType: 'C',
  entityKey: 'amara-brand',
  languages: {
    de: {
      title: 'AMARA Impressum & Datenschutzerklärung',
      description: 'Impressum, Lizenzen und Datenschutz. Inklusive Pflichtangaben nach TMG/DDG und andalusischem Tourismusrecht.',
      robots: 'index, follow',
      canonical: 'auto'
