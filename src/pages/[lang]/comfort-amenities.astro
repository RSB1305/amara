                <div class="am-btn-row">
                  <a href="https://amara-lodging.es/es/la-amara-lounis-apartamento-historico" class="am-btn am-btn--primary">Direct booking</a>
                </div>
              </div>
            </article>

            <article class="am-card" data-rental-id="408323">
              <div class="am-card-body">
                <h3 class="am-h2">AMARA Zaid</h3>
                <div class="am-prose">
                  <p class="am-body">
                    <a class="am-inline-link" href="https://amara-lodging.es/es/la-amara-zaid-refugio-romantico-con-terraza">View details (ES canonical)</a>
