                <div class="am-prose">
                  <p class="am-body">
                    <a class="am-inline-link" href="https://amara-lodging.es/es/la-amara-playa-apartamento-nerja">View details (ES canonical)</a>
                  </p>
                </div>

                <ul class="am-list-specs">
                  <li><strong>License (VFT)</strong> <span>VFT/MA/19212</span></li>
