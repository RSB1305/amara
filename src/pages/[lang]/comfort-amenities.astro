                  <li><strong>Bed</strong> <span>180×200</span></li>
                  <li><strong>Price</strong> <span>€90–€180</span></li>
                  <li><strong>Access note</strong> <span>Requires stairs</span></li>
                  <li><strong>Pets</strong> <span>Not allowed</span></li>
                  <li><strong>View</strong> <span>Distant sea view</span></li>
                  <li><strong>Outdoor</strong> <span>Private Terrace</span></li>
                  <li><strong>Kitchen</strong> <span>Full indoor kitchen</span></li>
                </ul>

                <div class="am-btn-row">
                  <a href="https://amara-lodging.es/es/la-amara-zaid-refugio-romantico-con-terraza" class="am-btn am-btn--primary">Direct booking</a>
                </div>
              </div>
            </article>

            <article class="am-card" data-rental-id="408325">
              <div class="am-card-body">
                <h3 class="am-h2">AMARA Maha</h3>
                <div class="am-prose">
                  <p class="am-body">
