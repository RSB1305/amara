---
import AboutUsPage from '../../page-families/amara-about-us/AboutUsPage.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'de' } },
    { params: { lang: 'nl' } },
    { params: { lang: 'sv' } }
  ];
}

const { lang } = Astro.params;
---

