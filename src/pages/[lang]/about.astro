---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { resolveLink } from '../../lib/linkResolver';
import { normalizeLanguage } from '../../lib/seo/resolve-seo-head';
import type { AmaraAuthoringSeo, AmaraLanguage } from '../../types/seo';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'de' } },
    { params: { lang: 'es' } },
    { params: { lang: 'nl' } },
    { params: { lang: 'sv' } }
  ];
}

const { lang } = Astro.params;
const currentLang = normalizeLanguage(lang as AmaraLanguage);

const seo: AmaraAuthoringSeo = {
  version: '2026-03-23-v1.0-C',
  pageType: 'C',
  entityKey: 'amara-brand',
  languages: {
    en: {
      title: 'AMARA | Holiday Apartments in Andalusia',
      description: 'The AMARA philosophy, quality standard, hosting approach, and brand identity.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    de: {
      title: 'AMARA | Ferienwohnungen in Andalusien',
      description: 'Die Philosophie, Qualitätsstandards, Hosting-Haltung und Markenidentität von AMARA.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    es: {
      title: 'AMARA | Apartamentos vacacionales en Andalucía',
      description: 'La filosofía, el estándar de calidad, la forma de alojar y la identidad de marca de AMARA.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    nl: {
      title: 'AMARA | Vakantieappartementen in Andalusië',
      description: 'De filosofie, kwaliteitsstandaard, hostingaanpak en merkidentiteit van AMARA.',
      robots: 'index, follow',
      canonical: 'auto'
    },
    sv: {
      title: 'AMARA | Semesterlägenheter i Andalusien',
      description: 'AMARAs filosofi, kvalitetsnivå, värdskap och varumärkesidentitet.',
      robots: 'index, follow',
      canonical: 'auto'
    }
  },
  ogImage: '/images/hero-frigiliana.jpg'
};
---

<BaseLayout seo={seo}>
  <div class="am-root px-12 pt-40 pb-28">
    <div class="am-wrap max-w-screen-lg mx-auto">
      <main class="am-main">
        <section class="am-prose border-b border-outline-variant/10 pb-20 mb-20">
          <span class="label-md text-primary mb-6 block">AMARA</span>
          <h1 class="font-headline text-[clamp(3.25rem,8vw,5.75rem)] leading-[0.94] tracking-tight italic text-on-surface font-light mb-10">
            AMARA — Holiday Apartments in Andalusia
          </h1>
          <p class="text-on-surface-variant text-xl italic opacity-80 mb-4">
            Frigiliana · Nerja · Tarifa
          </p>
          <p class="text-on-surface text-xl leading-relaxed max-w-2xl">
            You arrive, open the door, and feel immediate relief.
            Everything is prepared. Nothing asks for attention.
          </p>
        </section>

        <section class="am-prose space-y-6 mb-20">
          <h2 class="font-headline text-5xl md:text-6xl italic tracking-tight text-on-surface">
            AMARA means love
          </h2>
          <p class="text-on-surface-variant text-xl leading-relaxed">
            AMARA means love. Love for the details. Love for what we do.
            A kind of love that stays — because it&apos;s consistent, not loud.
          </p>
          <p class="text-on-surface-variant text-xl leading-relaxed">
            AMARA was built from years of travel and hosting experience — professional and personal — with one clear goal: a stay that feels effortless from the first minute.
          </p>
          <p class="text-on-surface-variant text-xl leading-relaxed">
            This name is not a promise for a moment. It is a promise for what remains afterwards: trust, return guests, and the feeling of having truly arrived.
          </p>
        </section>

        <section class="am-prose space-y-6 mb-20">
          <h2 class="font-headline text-5xl md:text-6xl italic tracking-tight text-on-surface">
            About us? Actually: about you.
          </h2>
          <p class="text-on-surface-variant text-xl leading-relaxed">
            Everything at AMARA is built around the guest. Not around trends. Not around platform logic. Not around short-term optimisation.
          </p>
          <p class="text-on-surface-variant text-xl leading-relaxed">
            Hosting here is a matter of trust. The guiding question is always: What makes this stay genuinely better for the guest?
          </p>
          <p class="text-on-surface-variant text-xl leading-relaxed">
            That question guides every decision — consistency, responsibility, and long-term guest satisfaction.
          </p>
          <blockquote class="border-l border-primary/20 pl-8 pt-1 text-on-surface text-2xl font-headline italic leading-relaxed">
            “Everything was exactly as described — even better when we arrived.”
          </blockquote>
        </section>

        <section class="am-prose space-y-8 mb-20">
          <h2 class="font-headline text-5xl md:text-6xl italic tracking-tight text-on-surface">
            What we do differently
          </h2>
          <div class="space-y-8">
            <p class="text-on-surface-variant text-lg leading-relaxed">
              <strong class="text-on-surface font-semibold">Prepared for real stays</strong><br />
              Comfort and daily usefulness first — not staged for photos.
            </p>
            <p class="text-on-surface-variant text-lg leading-relaxed">
              <strong class="text-on-surface font-semibold">Consistency over promises</strong><br />
              What you see is what you find — every season, every stay.
            </p>
            <p class="text-on-surface-variant text-lg leading-relaxed">
              <strong class="text-on-surface font-semibold">Calm, not stimulation</strong><br />
              Design supports rest — not visual noise.
            </p>
            <p class="text-on-surface-variant text-lg leading-relaxed">
              <strong class="text-on-surface font-semibold">Direct responsibility</strong><br />
              You communicate with the people responsible for your stay.
            </p>
            <p class="text-on-surface-variant text-lg leading-relaxed">
              <strong class="text-on-surface font-semibold">Privacy respected</strong><br />
              Present when needed, invisible otherwise.
            </p>
          </div>
          <p class="text-on-surface-variant text-xl leading-relaxed italic">
            These choices are intentional. They are also not for everyone — and that is exactly the point.
          </p>
        </section>

        <section class="am-prose space-y-8 mb-20">
          <h2 class="font-headline text-5xl md:text-6xl italic tracking-tight text-on-surface">
            Honest quality in every AMARA home
          </h2>
          <div class="space-y-8">
            <p class="text-on-surface-variant text-lg leading-relaxed">
              <strong class="text-on-surface font-semibold">Deep sleep</strong><br />
              High-quality mattresses, crisp linens, quiet nights.
            </p>
            <p class="text-on-surface-variant text-lg leading-relaxed">
              <strong class="text-on-surface font-semibold">Cleanliness (non-negotiable)</strong><br />
              Thorough preparation — never rushed, never “good enough”.
            </p>
            <p class="text-on-surface-variant text-lg leading-relaxed">
              <strong class="text-on-surface font-semibold">Materials that age well</strong><br />
              Durable choices instead of quick fixes.
            </p>
            <p class="text-on-surface-variant text-lg leading-relaxed">
              <strong class="text-on-surface font-semibold">Reliable equipment</strong><br />
              Useful details, not showroom gimmicks.
            </p>
          </div>
          <p class="text-on-surface-variant text-xl leading-relaxed">
            If something no longer meets our standards, it is replaced — quietly, consistently, without discussion.
          </p>
        </section>

        <section class="am-prose space-y-6 mb-20">
          <h2 class="font-headline text-5xl md:text-6xl italic tracking-tight text-on-surface">
            Stable pricing. No discounts.
          </h2>
          <p class="text-on-surface-variant text-xl leading-relaxed">
            AMARA is not the cheapest option — and it is not designed to be. Reliable quality, care, and continuous reinvestment have real costs.
          </p>
          <p class="text-on-surface-variant text-xl leading-relaxed">
            Pricing is stable, transparent, and intentional — without flash deals or artificial promotions.
          </p>
          <p class="text-on-surface-variant text-xl leading-relaxed">
            If you are looking for the lowest price, AMARA is not the right fit.
          </p>
        </section>

        <section class="am-prose space-y-8 mb-20">
          <h2 class="font-headline text-5xl md:text-6xl italic tracking-tight text-on-surface">
            Our locations in Andalusia
          </h2>
          <p class="text-on-surface-variant text-xl leading-relaxed">
            Each AMARA location is chosen for atmosphere, rhythm, and the kind of stay it makes possible.
          </p>
          <div class="space-y-10">
            <div>
              <h3 class="font-headline text-3xl italic text-on-surface mb-3">Frigiliana</h3>
              <p class="text-on-surface-variant text-lg leading-relaxed">Quiet depth, white village calm, and a sense of time.</p>
            </div>
            <div>
              <h3 class="font-headline text-3xl italic text-on-surface mb-3">Nerja</h3>
              <p class="text-on-surface-variant text-lg leading-relaxed">Sea rhythm, authentic energy — with balance and ease.</p>
            </div>
            <div>
              <h3 class="font-headline text-3xl italic text-on-surface mb-3">Tarifa</h3>
              <p class="text-on-surface-variant text-lg leading-relaxed">Wide horizons, light and wind — active outdoors, calm indoors.</p>
            </div>
          </div>
        </section>

        <section class="am-prose space-y-8 mb-20">
          <h2 class="font-headline text-5xl md:text-6xl italic tracking-tight text-on-surface">
            Your host
          </h2>
          <p class="text-on-surface text-2xl font-headline italic">Robert — Founder & Host</p>
          <div class="space-y-8">
            <p class="text-on-surface-variant text-lg leading-relaxed">
              <strong class="text-on-surface font-semibold">Fast replies</strong><br />
              Clear, direct, reliable communication.
            </p>
            <p class="text-on-surface-variant text-lg leading-relaxed">
              <strong class="text-on-surface font-semibold">Present, not intrusive</strong><br />
              Reachable when needed, invisible otherwise.
            </p>
            <p class="text-on-surface-variant text-lg leading-relaxed">
              <strong class="text-on-surface font-semibold">Languages</strong><br />
              DE · EN · ES
            </p>
            <p class="text-on-surface-variant text-lg leading-relaxed">
              <strong class="text-on-surface font-semibold">Insider guidance</strong><br />
              Curated recommendations for calm, authentic experiences.
            </p>
          </div>
        </section>

        <section class="am-prose space-y-8 mb-20">
          <h2 class="font-headline text-5xl md:text-6xl italic tracking-tight text-on-surface">
            A small team. One standard.
          </h2>
          <div class="space-y-8">
            <p class="text-on-surface-variant text-lg leading-relaxed">
              <strong class="text-on-surface font-semibold">Small and trusted</strong><br />
              A team that shares the same standards.
            </p>
            <p class="text-on-surface-variant text-lg leading-relaxed">
              <strong class="text-on-surface font-semibold">The same every stay</strong><br />
              Care applied consistently — not selectively.
            </p>
            <p class="text-on-surface-variant text-lg leading-relaxed">
              <strong class="text-on-surface font-semibold">Quiet execution</strong><br />
              Quality happens in the background — so the stay feels effortless.
            </p>
          </div>
        </section>

        <section class="am-prose space-y-8 mb-24">
          <h2 class="font-headline text-5xl md:text-6xl italic tracking-tight text-on-surface">
            AMARA Earth
          </h2>
          <p class="text-on-surface-variant text-xl leading-relaxed">
            Sustainable by choice.
          </p>
          <p class="text-on-surface-variant text-xl leading-relaxed">
            Sustainability at AMARA means practical decisions that reduce impact without reducing comfort.
          </p>
          <div class="space-y-8">
            <p class="text-on-surface-variant text-lg leading-relaxed">
              <strong class="text-on-surface font-semibold">Energy</strong><br />
              Solar hot water · Renewable electricity · LED lighting · Efficient appliances
            </p>
            <p class="text-on-surface-variant text-lg leading-relaxed">
              <strong class="text-on-surface font-semibold">Water &amp; waste</strong><br />
              Low-flow showers · Recycling · Refillable amenities · No capsule coffee systems
            </p>
          </div>
        </section>

        <section class="am-prose border-t border-outline-variant/10 pt-16">
          <h2 class="font-headline text-5xl md:text-6xl italic tracking-tight text-on-surface mb-8">
            If you value reliability, you&apos;ll feel at home here
          </h2>
          <p class="text-on-surface-variant text-xl leading-relaxed mb-6">
            AMARA is for guests who appreciate calm execution, honest communication, and places that feel considered rather than staged.
          </p>
          <p class="text-on-surface-variant text-xl leading-relaxed mb-10">
            Many guests return — because expectations are met, quietly and consistently.
          </p>
          <p class="text-on-surface text-lg leading-relaxed">
            <a href={resolveLink('book', currentLang)} class="underline decoration-outline-variant underline-offset-4 hover:text-primary transition-colors">Check availability</a>
            <span class="mx-3 text-outline">·</span>
            <a href={resolveLink('reviews_hub', currentLang)} class="underline decoration-outline-variant underline-offset-4 hover:text-primary transition-colors">Guest reviews</a>
            <span class="mx-3 text-outline">·</span>
            <a href={resolveLink('direct_booking_benefits', currentLang)} class="underline decoration-outline-variant underline-offset-4 hover:text-primary transition-colors">Direct booking benefits</a>
          </p>
        </section>
      </main>
    </div>
  </div>
</BaseLayout>
